@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject IJSRuntime JS
@inject ApiClient Api
@inject TimezoneService TzService
@implements IDisposable

<aside class="sidebar @(sidebarOpen ? "open" : "") @(sidebarCollapsed ? "collapsed" : "")" id="sidebar">
    <div class="sidebar-brand">
        <span class="sidebar-brand-icon">@SvgIcons.Brand</span>
        <span class="sidebar-brand-text">Integraly</span>
        <button class="sidebar-collapse-btn" @onclick="ToggleCollapse" title="@(sidebarCollapsed ? "Expandir menu" : "Colapsar menu")">
            <span class="sidebar-collapse-icon">@(sidebarCollapsed ? SvgIcons.ChevronRight : SvgIcons.ChevronLeft)</span>
        </button>
    </div>
    <nav class="sidebar-nav" role="navigation" aria-label="Menu principal">
        @if (HasPerm("dashboard"))
        {
            <NavItem Href="" Label="Dashboard" Icon="@SvgIcons.Dashboard"
                     IsActive="@IsActive("")" OnClick="@(() => NavigateTo(""))" />
        }

        @if (role != "admin" && (HasPerm("calendario") || HasPerm("reservar") || HasPerm("mis-reservas") || HasPerm("fichajes")))
        {
            <NavGroup Label="Tutorias" Icon="@SvgIcons.Calendar"
                      HasActiveChild="@(IsActive("calendario") || IsActive("reservar") || IsActive("mis-reservas") || IsActive("fichajes"))">
                @if (HasPerm("calendario"))
                {
                    <NavItem Href="calendario" Label="Calendario" Icon="@SvgIcons.Calendar"
                             IsActive="@IsActive("calendario")" OnClick="@(() => NavigateTo("calendario"))" />
                }
                @if (HasPerm("reservar"))
                {
                    <NavItem Href="reservar" Label="Reservar" Icon="@SvgIcons.Clock"
                             IsActive="@IsActive("reservar")" OnClick="@(() => NavigateTo("reservar"))" />
                }
                @if (HasPerm("mis-reservas"))
                {
                    <NavItem Href="mis-reservas" Label="Mis Reservas" Icon="@SvgIcons.CheckCircle"
                             IsActive="@IsActive("mis-reservas")" OnClick="@(() => NavigateTo("mis-reservas"))" />
                }
                @if (HasPerm("fichajes"))
                {
                    <NavItem Href="fichajes" Label="Fichajes" Icon="@SvgIcons.ClockIn"
                             IsActive="@IsActive("fichajes")" OnClick="@(() => NavigateTo("fichajes"))" />
                }
            </NavGroup>
        }

        @if (HasPerm("usuarios") || HasPerm("roles") || HasPerm("invitaciones") || HasPerm("packs") || HasPerm("todas-reservas") || HasPerm("auditoria") || HasPerm("config") || role == "admin")
        {
            <NavGroup Label="Administracion" Icon="@SvgIcons.Admin"
                      HasActiveChild="@(IsActive("calendario-admin") || IsActive("usuarios") || IsActive("roles") || IsActive("invitaciones") || IsActive("packs") || IsActive("todas-reservas") || IsActive("auditoria") || IsActive("config"))">
                @if (role == "admin")
                {
                    <NavItem Href="calendario-admin" Label="Calendario" Icon="@SvgIcons.Calendar"
                             IsActive="@IsActive("calendario-admin")" OnClick="@(() => NavigateTo("calendario-admin"))" />
                }
                @if (HasPerm("usuarios"))
                {
                    <NavItem Href="usuarios" Label="Usuarios" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("usuarios")" OnClick="@(() => NavigateTo("usuarios"))" />
                }
                @if (HasPerm("roles"))
                {
                    <NavItem Href="roles" Label="Roles" Icon="@SvgIcons.Shield"
                             IsActive="@IsActive("roles")" OnClick="@(() => NavigateTo("roles"))" />
                }
                @if (HasPerm("invitaciones"))
                {
                    <NavItem Href="invitaciones" Label="Invitaciones" Icon="@SvgIcons.Mail"
                             IsActive="@IsActive("invitaciones")" OnClick="@(() => NavigateTo("invitaciones"))" />
                }
                @if (HasPerm("packs"))
                {
                    <NavItem Href="packs" Label="Packs de Clases" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("packs")" OnClick="@(() => NavigateTo("packs"))" />
                }
                @if (HasPerm("todas-reservas"))
                {
                    <NavItem Href="todas-reservas" Label="Todas las Reservas" Icon="@SvgIcons.List"
                             IsActive="@IsActive("todas-reservas")" OnClick="@(() => NavigateTo("todas-reservas"))" />
                }
                @if (HasPerm("auditoria"))
                {
                    <NavItem Href="auditoria" Label="Auditoria" Icon="@SvgIcons.History"
                             IsActive="@IsActive("auditoria")" OnClick="@(() => NavigateTo("auditoria"))" />
                }
                @if (HasPerm("config"))
                {
                    <NavItem Href="config" Label="Configuracion" Icon="@SvgIcons.Settings"
                             IsActive="@IsActive("config")" OnClick="@(() => NavigateTo("config"))" />
                }
            </NavGroup>
        }
    </nav>
    <div class="sidebar-user">
        <div class="sidebar-user-avatar">@SvgIcons.User</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">@username</span>
            <span class="sidebar-user-role">@role</span>
        </div>
        <button class="sidebar-menu-btn" @onclick="ToggleUserMenu" @onclick:stopPropagation="true" title="Menu">
            <span class="sidebar-menu-icon @(userMenuOpen ? "rotated" : "")">@SvgIcons.ChevronUp</span>
        </button>
        @if (userMenuOpen)
        {
            <div class="sidebar-user-dropdown">
                <button class="sidebar-dropdown-item" @onclick="GoToProfile">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Edit</span>
                    <span class="sidebar-dropdown-text">Editar Perfil</span>
                </button>
                <button class="sidebar-dropdown-item sidebar-dropdown-danger" @onclick="Logout">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Logout</span>
                    <span class="sidebar-dropdown-text">Cerrar Sesion</span>
                </button>
            </div>
        }
    </div>
</aside>

<main class="main-wrapper @(sidebarCollapsed ? "main-collapsed" : "")">
    <header class="topbar">
        <div class="topbar-left">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Abrir menu">
                @SvgIcons.Menu
            </button>
            <h1 class="topbar-title">Integraly</h1>
        </div>
        <div class="topbar-actions">
            <button class="topbar-btn" @onclick="Refresh" title="Actualizar">
                @SvgIcons.Refresh
            </button>
        </div>
    </header>
    <div class="content">
        @Body
    </div>
</main>

@if (sidebarOpen)
{
    <div class="sidebar-overlay visible" @onclick="CloseSidebar"></div>
}

<ToastContainer />

@code {
    private bool sidebarOpen;
    private bool sidebarCollapsed;
    private bool userMenuOpen;
    private string username = "usuario";
    private string role = "user";
    private List<string> permissions = new();

    private static readonly Dictionary<string, string> RouteToMenuKey = new()
    {
        { "", "dashboard" },
        { "calendario", "calendario" },
        { "calendario-admin", "calendario-admin" },
        { "reservar", "reservar" },
        { "mis-reservas", "mis-reservas" },
        { "usuarios", "usuarios" },
        { "roles", "roles" },
        { "invitaciones", "invitaciones" },
        { "packs", "packs" },
        { "todas-reservas", "todas-reservas" },
        { "auditoria", "auditoria" },
        { "config", "config" },
        { "perfil", "" } // perfil always allowed
    };

    private bool IsAdminPanel => Navigation.BaseUri.Contains("/admin/");

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            role = user.Role;
            permissions = user.Permissions ?? new();
            TzService.SetTimezone(user.Timezone ?? "America/Argentina/Buenos_Aires");

            // Redirect to correct panel based on role
            if (role == "admin" && !IsAdminPanel)
            {
                Navigation.NavigateTo("/admin/", forceLoad: true);
                return;
            }
            else if (role != "admin" && IsAdminPanel)
            {
                Navigation.NavigateTo("/panel/", forceLoad: true);
                return;
            }
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.LocationChanged += OnLocationChanged;
            CheckRoutePermission();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CheckRoutePermission();
    }

    private void CheckRoutePermission()
    {
        if (permissions.Count == 0) return;

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/').Split('?')[0].Split('#')[0];

        if (RouteToMenuKey.TryGetValue(relativePath, out var menuKey))
        {
            if (!string.IsNullOrEmpty(menuKey) && !permissions.Contains(menuKey))
            {
                Navigation.NavigateTo("");
            }
        }
    }

    private bool HasPerm(string key) => role == "admin" || permissions.Contains(key);

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool IsActive(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (href == "/" || href == "")
            return string.IsNullOrEmpty(relativePath) || relativePath == "/" || relativePath.Equals("index.html", StringComparison.OrdinalIgnoreCase);
        return relativePath.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string url)
    {
        CloseSidebar();
        Navigation.NavigateTo(url);
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;
    private void ToggleCollapse()
    {
        sidebarCollapsed = !sidebarCollapsed;
        userMenuOpen = false;
    }
    private void ToggleUserMenu() => userMenuOpen = !userMenuOpen;

    private void GoToProfile()
    {
        userMenuOpen = false;
        CloseSidebar();
        Navigation.NavigateTo("perfil");
    }

    private void Refresh()
    {
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private async Task Logout()
    {
        userMenuOpen = false;
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("login", forceLoad: true);
    }
}
