@page "/pago-pendiente"
@attribute [Authorize]
@inject NavigationManager Navigation

<div class="pago-result-container">
    <div class="pago-result-card pago-pending">
        <div class="pago-result-icon">
            @SvgIcons.Clock
        </div>
        <h2 class="pago-result-title">Pago pendiente</h2>
        <p class="pago-result-message">Tu pago esta siendo procesado. Te vamos a avisar por email cuando este confirmado.</p>
        <div class="pago-result-actions">
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("comprar")'>
                Ver planes
            </button>
            <button class="btn btn-outline" @onclick='() => Navigation.NavigateTo("")'>
                Ir al Dashboard
            </button>
        </div>
    </div>
</div>
