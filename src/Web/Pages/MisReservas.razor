@page "/mis-reservas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject TimezoneService TzService

<div class="card" style="margin-bottom: 1rem;">
    <div class="card-body" style="padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <div style="display: flex; gap: 0.5rem;">
            <button class="btn @(view == "list" ? "btn-primary" : "btn-secondary") btn-sm" @onclick='() => view = "list"'><i class="fa-solid fa-list" style="margin-right:0.3rem;"></i>Lista</button>
            <button class="btn @(view == "week" ? "btn-primary" : "btn-secondary") btn-sm" @onclick='() => { view = "week"; }'><i class="fa-solid fa-calendar-week" style="margin-right:0.3rem;"></i>Semanal</button>
            <button class="btn @(view == "month" ? "btn-primary" : "btn-secondary") btn-sm" @onclick='() => { view = "month"; }'><i class="fa-solid fa-calendar" style="margin-right:0.3rem;"></i>Mensual</button>
        </div>
        @if (view == "week")
        {
            <div class="week-navigator">
                <button class="btn btn-secondary btn-sm" @onclick="PrevWeek"><i class="fa-solid fa-chevron-left"></i></button>
                <span class="week-label">@weekStart.ToString("dd/M") — @weekEnd.ToString("dd/M/yyyy")</span>
                <button class="btn btn-secondary btn-sm" @onclick="NextWeek"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        }
        @if (view == "month")
        {
            <div class="week-navigator">
                <button class="btn btn-secondary btn-sm" @onclick="PrevMonth"><i class="fa-solid fa-chevron-left"></i></button>
                <span class="week-label">@monthDate.ToString("MMMM yyyy")</span>
                <button class="btn btn-secondary btn-sm" @onclick="NextMonth"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        }
    </div>
</div>

@if (isLoading)
{
    <div class="card"><div class="card-body"><p class="text-muted">Cargando...</p></div></div>
}
else if (view == "list")
{
    @* === VISTA LISTA === *@
    <div class="card">
        <div class="card-body" style="padding: 0;">
            @if (bookings is null || !bookings.Any())
            {
                <p class="text-muted" style="padding: 1.5rem;">No tenes reservas todavia</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Horario</th>
                                <th>@(isInstructor ? "Alumno" : "Instructor")</th>
                                <th>Estado</th>
                                <th>Meet</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in bookings.OrderBy(b => b.ScheduledDate).ThenBy(b => b.StartHour))
                            {
                                <tr>
                                    <td>@b.ScheduledDate.ToString("dd/MM/yyyy")</td>
                                    <td>@($"{b.StartHour:00}:00 - {b.StartHour + 1:00}:00")</td>
                                    <td>@(isInstructor ? b.UserName : b.InstructorName)</td>
                                    <td><span class="status-badge @GetStatusClass(b.Status)">@GetStatusText(b.Status)</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(b.MeetLink) && b.Status == "confirmed")
                                        {
                                            <a href="@b.MeetLink" target="_blank" class="btn btn-sm btn-primary"><i class="fa-solid fa-video" style="margin-right:0.3rem;"></i>Entrar</a>
                                        }
                                        else { <span class="text-muted">-</span> }
                                    </td>
                                    <td>
                                        @if (b.Status == "confirmed" && b.ScheduledDate >= DateTime.Today && !isInstructor)
                                        {
                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmCancel(b)"><i class="fa-solid fa-ban" style="margin-right:0.3rem;"></i>Cancelar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else if (view == "week")
{
    @* === VISTA SEMANAL === *@
    <div class="card">
        <div class="card-body" style="padding: 0.5rem;">
            <div class="table-responsive">
                <table class="data-table calendar-compact">
                    <thead>
                        <tr>
                            <th style="width:50px;">Hora</th>
                            @for (int i = 0; i < 7; i++)
                            {
                                var d = weekStart.AddDays(i);
                                var isToday = d.Date == DateTime.Today;
                                <th style="text-align:center;@(isToday ? "background:var(--primary-bg);" : "")">
                                    <div style="font-size:0.75rem;">@dayNames[i]</div>
                                    <div style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">@d.ToString("dd/M")</div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int hour = 7; hour <= 22; hour++)
                        {
                            var h = hour;
                            var hasAny = false;
                            @for (int i = 0; i < 7; i++) { if (GetBookingAt(weekStart.AddDays(i), h) is not null) { hasAny = true; break; } }
                            @if (hasAny || (h >= 8 && h <= 21))
                            {
                                <tr>
                                    <td style="font-size:0.75rem;font-weight:600;padding:4px;">@($"{h:00}:00")</td>
                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var d = weekStart.AddDays(i);
                                        var b = GetBookingAt(d, h);
                                        var isToday = d.Date == DateTime.Today;
                                        var isPast = d.Date < DateTime.Today || (d.Date == DateTime.Today && h < DateTime.Now.Hour);
                                        @if (b is not null)
                                        {
                                            var booking = b;
                                            var isCompleted = b.Status == "completed";
                                            var isCancelled = b.Status == "cancelled";
                                            <td style="text-align:center;padding:4px;font-size:0.75rem;cursor:pointer;@(isToday ? "background:rgba(16,185,129,0.03);" : "") @(isPast ? "opacity:0.5;" : "")"
                                                class="@(isCompleted ? "calendar-slot-completed" : isCancelled ? "calendar-inactive" : "calendar-slot-booked")"
                                                @onclick="() => ShowDetail(booking)">
                                                <div style="display:flex;flex-direction:column;align-items:center;gap:1px;">
                                                    @if (isCompleted)
                                                    {
                                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                                    }
                                                    else if (isCancelled)
                                                    {
                                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                                    }
                                                    <span style="font-size:0.6rem;line-height:1;max-width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                        @(isInstructor ? booking.UserName : booking.InstructorName)
                                                    </span>
                                                </div>
                                            </td>
                                        }
                                        else
                                        {
                                            <td style="text-align:center;padding:4px;font-size:0.75rem;@(isToday ? "background:rgba(16,185,129,0.03);" : "") @(isPast ? "opacity:0.5;" : "")"></td>
                                        }
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.8rem; flex-wrap: wrap; padding: 0 0.5rem; align-items: center;">
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#3b82f6;"></span>
                    Confirmada
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#10b981;"></span>
                    Realizada
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#ef4444;"></span>
                    Cancelada
                </span>
            </div>
        </div>
    </div>
}
else if (view == "month")
{
    @* === VISTA MENSUAL === *@
    <div class="card">
        <div class="card-body">
            <div class="month-grid">
                <div class="month-header">
                    @foreach (var d in dayNames)
                    {
                        <div class="month-day-label">@d</div>
                    }
                </div>
                <div class="month-body">
                    @* Empty cells before first day *@
                    @{ var firstDay = new DateTime(monthDate.Year, monthDate.Month, 1); }
                    @{ var startDow = ((int)firstDay.DayOfWeek + 6) % 7; }
                    @for (int i = 0; i < startDow; i++)
                    {
                        <div class="month-cell empty"></div>
                    }
                    @* Days of month *@
                    @{ var daysInMonth = DateTime.DaysInMonth(monthDate.Year, monthDate.Month); }
                    @for (int day = 1; day <= daysInMonth; day++)
                    {
                        var date = new DateTime(monthDate.Year, monthDate.Month, day);
                        var dayBookings = GetBookingsForDate(date);
                        var isToday = date.Date == DateTime.Today;
                        <div class="month-cell @(isToday ? "today" : "") @(dayBookings.Count > 0 ? "has-bookings" : "")">
                            <div class="month-cell-day">@day</div>
                            @if (dayBookings.Count > 0)
                            {
                                @foreach (var b in dayBookings.Take(3))
                                {
                                    <div class="month-booking @(b.Status == "confirmed" ? "confirmed" : "cancelled")"
                                         title="@($"{b.StartHour:00}:00 - {(isInstructor ? b.UserName : b.InstructorName)}")">
                                        @($"{b.StartHour:00}:00") @(isInstructor ? b.UserName : b.InstructorName)
                                    </div>
                                }
                                @if (dayBookings.Count > 3)
                                {
                                    <div class="month-booking more">+@(dayBookings.Count - 3) mas</div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showDetailModal && detailBooking is not null)
{
    <div class="modal-overlay" @onclick="() => showDetailModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Detalle de clase</h3>
            </div>
            <div class="modal-body">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
                    @if (detailBooking.Status == "completed")
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(16,185,129,0.12);color:#10b981;padding:4px 10px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                            @SvgIcons.CheckCircle Realizada
                        </span>
                    }
                    else if (detailBooking.Status == "cancelled")
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(239,68,68,0.12);color:#ef4444;padding:4px 10px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                            @SvgIcons.AlertCircle Cancelada
                        </span>
                    }
                    else
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(59,130,246,0.12);color:#3b82f6;padding:4px 10px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                            @SvgIcons.Calendar Confirmada
                        </span>
                    }
                </div>

                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.Calendar</span>
                        <span><strong>Fecha:</strong> @detailBooking.ScheduledDate.ToString("dddd dd/MM/yyyy")</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.Clock</span>
                        <span><strong>Horario:</strong> @($"{detailBooking.StartHour:00}:00 - {detailBooking.StartHour + 1:00}:00")</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.User</span>
                        <span><strong>@(isInstructor ? "Alumno:" : "Instructor:")</strong> @(isInstructor ? detailBooking.UserName : detailBooking.InstructorName)</span>
                    </div>

                    @if (!string.IsNullOrEmpty(detailBooking.MeetLink) && detailBooking.Status != "cancelled")
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.ExternalLink</span>
                            <a href="@detailBooking.MeetLink" target="_blank" rel="noopener" class="btn btn-sm" style="background:#10b981;color:white;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                <i class="fa-solid fa-video" style="margin-right:0.3rem;"></i>Unirse a la clase
                            </a>
                        </div>
                    }
                    else if (detailBooking.Status == "confirmed")
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.ExternalLink</span>
                            <span style="font-size:0.85rem;color:var(--text-muted);">El link de Meet se asignara antes de la clase</span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDetailModal = false"><i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cerrar</button>
                @if (detailBooking.Status == "confirmed" && !isInstructor)
                {
                    <button class="btn btn-danger" @onclick="CancelFromDetail" disabled="@isCancellingDetail">
                        <i class="fa-solid fa-calendar-xmark" style="margin-right:0.3rem;"></i>@(isCancellingDetail ? "Cancelando..." : "Cancelar Reserva")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<BookingDto>? bookings;
    private bool isLoading = true;
    private bool isInstructor;
    private string view = "list";

    // Detail modal
    private bool showDetailModal;
    private BookingDto? detailBooking;
    private bool isCancellingDetail;

    // Legacy cancel (list view)
    private bool showCancelConfirm;
    private BookingDto? bookingToCancel;

    // Week navigation
    private DateTime weekStart;
    private DateTime weekEnd;
    private string[] dayNames = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };

    // Month navigation
    private DateTime monthDate;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        var dow = (int)today.DayOfWeek;
        var daysToMon = dow == 0 ? 6 : dow - 1;
        weekStart = today.AddDays(-daysToMon);
        weekEnd = weekStart.AddDays(6);
        monthDate = new DateTime(today.Year, today.Month, 1);

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            bookings = await Api.GetMyBookingsAsync();
            var user = await Api.GetProfileAsync();
            isInstructor = user?.Role?.ToLower() == "instructor";
            if (isInstructor && view == "list") view = "week";
        }
        catch
        {
            ToastService.Error("Error al cargar las reservas");
        }
        isLoading = false;
    }

    // Week helpers
    private void PrevWeek() { weekStart = weekStart.AddDays(-7); weekEnd = weekEnd.AddDays(-7); }
    private void NextWeek() { weekStart = weekStart.AddDays(7); weekEnd = weekEnd.AddDays(7); }

    private BookingDto? GetBookingAt(DateTime date, int hour)
    {
        return bookings?.FirstOrDefault(b => b.ScheduledDate.Date == date.Date && b.StartHour == hour);
    }

    // Month helpers
    private void PrevMonth() { monthDate = monthDate.AddMonths(-1); }
    private void NextMonth() { monthDate = monthDate.AddMonths(1); }

    private List<BookingDto> GetBookingsForDate(DateTime date)
    {
        return bookings?.Where(b => b.ScheduledDate.Date == date.Date)
            .OrderBy(b => b.StartHour).ToList() ?? new();
    }

    // Cancel
    private void ConfirmCancel(BookingDto booking) { bookingToCancel = booking; showCancelConfirm = true; }

    private async Task CancelBooking()
    {
        if (bookingToCancel is null) return;
        var result = await Api.CancelBookingAsync(bookingToCancel.Id);
        if (result) { ToastService.Success("Reserva cancelada"); await LoadData(); }
        else { ToastService.Error("No se pudo cancelar. Puede que ya haya pasado el tiempo limite."); }
        showCancelConfirm = false;
        bookingToCancel = null;
    }

    // Detail modal
    private void ShowDetail(BookingDto booking)
    {
        detailBooking = booking;
        showDetailModal = true;
    }

    private async Task CancelFromDetail()
    {
        if (detailBooking is null) return;
        isCancellingDetail = true;
        var result = await Api.CancelBookingAsync(detailBooking.Id);
        if (result)
        {
            ToastService.Success("Reserva cancelada");
            showDetailModal = false;
            await LoadData();
        }
        else
        {
            ToastService.Error("No se pudo cancelar la reserva");
        }
        isCancellingDetail = false;
    }

    private string GetStatusClass(string s) => s switch { "confirmed" => "status-active", "cancelled" => "status-inactive", "completed" => "status-active", _ => "" };
    private string GetStatusText(string s) => s switch { "confirmed" => "Confirmada", "cancelled" => "Cancelada", "completed" => "Completada", _ => s };
}
