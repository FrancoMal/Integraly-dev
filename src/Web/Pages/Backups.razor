@page "/backups"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<div class="card">
    <div class="card-header">
        <h3>Backup de Base de Datos</h3>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            <div style="margin-bottom: 1rem;">
                <button class="btn btn-primary" @onclick="CreateBackup" disabled="@isCreating">
                    <i class="fa-solid fa-download" style="margin-right:0.3rem;"></i>@(isCreating ? "Creando backup..." : "Crear Backup Manual")
                </button>
            </div>

            @if (backups == null || backups.Count == 0)
            {
                <p class="text-muted">No hay backups</p>
            }
            else
            {
                <table style="width:100%; border-collapse:collapse; margin-top:1rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Fecha</th>
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Archivo</th>
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Tamano</th>
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Tipo</th>
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Estado</th>
                            <th style="text-align:left; padding:0.75rem 0.5rem; color:rgba(255,255,255,0.5); font-weight:500; font-size:0.85rem;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var backup in backups)
                        {
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <td style="padding:0.75rem 0.5rem;">@backup.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="padding:0.75rem 0.5rem; font-size:0.9rem; word-break:break-all;">@backup.FileName</td>
                                <td style="padding:0.75rem 0.5rem;">@backup.SizeFormatted</td>
                                <td style="padding:0.75rem 0.5rem;">
                                    @(backup.Type == "manual" ? "Manual" : "Programado")
                                </td>
                                <td style="padding:0.75rem 0.5rem;">
                                    @switch (backup.Status)
                                    {
                                        case "completed":
                                            <span style="padding:0.2rem 0.6rem; border-radius:12px; font-size:0.8rem; background:#22c55e20; color:#22c55e;">Completado</span>
                                            break;
                                        case "failed":
                                            <span style="padding:0.2rem 0.6rem; border-radius:12px; font-size:0.8rem; background:#ef444420; color:#ef4444;" title="@backup.ErrorMessage">Fallido</span>
                                            break;
                                        case "in_progress":
                                            <span style="padding:0.2rem 0.6rem; border-radius:12px; font-size:0.8rem; background:#f59e0b20; color:#f59e0b;">En progreso</span>
                                            break;
                                        case "file_missing":
                                            <span style="padding:0.2rem 0.6rem; border-radius:12px; font-size:0.8rem; background:#6b728020; color:#6b7280;">Archivo no encontrado</span>
                                            break;
                                        default:
                                            <span style="padding:0.2rem 0.6rem; border-radius:12px; font-size:0.8rem; background:#6b728020; color:#6b7280;">@backup.Status</span>
                                            break;
                                    }
                                </td>
                                <td style="padding:0.75rem 0.5rem;">
                                    <div style="display:flex; gap:0.5rem;">
                                        @if (backup.Status == "completed")
                                        {
                                            <button class="btn btn-secondary" style="padding:0.3rem 0.6rem; font-size:0.8rem;"
                                                    @onclick="() => DownloadBackup(backup.Id, backup.FileName)"
                                                    disabled="@(downloadingId == backup.Id)">
                                                <i class="fa-solid fa-file-arrow-down" style="margin-right:0.2rem;"></i>@(downloadingId == backup.Id ? "Descargando..." : "Descargar")
                                            </button>
                                        }
                                        <button class="btn btn-danger" style="padding:0.3rem 0.6rem; font-size:0.8rem;"
                                                @onclick="() => ConfirmDelete(backup)"
                                                disabled="@(deletingId == backup.Id)">
                                            <i class="fa-solid fa-trash" style="margin-right:0.2rem;"></i>@(deletingId == backup.Id ? "Eliminando..." : "Eliminar")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</div>

@if (showDeleteConfirm)
{
    <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000;" @onclick="CancelDelete">
        <div style="background:#1e293b; border-radius:12px; padding:1.5rem; max-width:400px; width:90%;" @onclick:stopPropagation="true">
            <h4 style="margin-bottom:1rem;">Confirmar eliminacion</h4>
            <p style="margin-bottom:1rem; color:rgba(255,255,255,0.7);">Estas seguro que deseas eliminar el backup <strong>@backupToDelete?.FileName</strong>?</p>
            <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                <button class="btn btn-secondary" @onclick="CancelDelete">Cancelar</button>
                <button class="btn btn-danger" @onclick="DeleteBackup">Eliminar</button>
            </div>
        </div>
    </div>
}

<div class="card" style="margin-top: 1.5rem;">
    <div class="card-header">
        <h3>Programacion Automatica</h3>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="scheduleEnabled" @bind="scheduleEnabled" />
                <label for="scheduleEnabled" class="form-label" style="margin: 0;">Activar backups automaticos</label>
            </div>

            @if (scheduleEnabled)
            {
                <div class="form-group">
                    <label class="form-label">Intervalo entre backups</label>
                    <select class="form-input" @bind="scheduleIntervalHours">
                        <option value="6">Cada 6 horas</option>
                        <option value="12">Cada 12 horas</option>
                        <option value="24">Cada 24 horas</option>
                        <option value="48">Cada 48 horas</option>
                        <option value="168">Cada 7 dias (168 horas)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Dias de retencion</label>
                    <input class="form-input" type="number" @bind="scheduleRetentionDays" min="1" max="365" />
                    <small class="text-muted">Los backups mas antiguos que esta cantidad de dias se eliminan automaticamente</small>
                </div>
            }

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveSchedule" disabled="@isSavingSchedule">
                    <i class="fa-solid fa-floppy-disk" style="margin-right:0.3rem;"></i>@(isSavingSchedule ? "Guardando..." : "Guardar Programacion")
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isCreating;
    private bool isSavingSchedule;
    private int? downloadingId;
    private int? deletingId;

    private List<BackupDto>? backups;

    // Schedule fields
    private bool scheduleEnabled;
    private int scheduleIntervalHours = 24;
    private int scheduleRetentionDays = 30;

    // Delete confirmation
    private bool showDeleteConfirm;
    private BackupDto? backupToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            backups = await Api.GetBackupsAsync();
            var schedule = await Api.GetBackupScheduleAsync();
            if (schedule != null)
            {
                scheduleEnabled = schedule.Enabled;
                scheduleIntervalHours = schedule.IntervalHours;
                scheduleRetentionDays = schedule.RetentionDays;
            }
        }
        catch
        {
            ToastService.Error("Error al cargar los backups");
        }
        isLoading = false;
    }

    private async Task CreateBackup()
    {
        isCreating = true;
        try
        {
            var result = await Api.CreateBackupAsync();
            if (result != null)
            {
                ToastService.Success("Backup creado correctamente");
                await LoadData();
            }
            else
            {
                ToastService.Error("Error al crear el backup");
            }
        }
        catch
        {
            ToastService.Error("Error al crear el backup");
        }
        isCreating = false;
    }

    private async Task DownloadBackup(int id, string fileName)
    {
        downloadingId = id;
        StateHasChanged();
        try
        {
            var bytes = await Api.DownloadBackupAsync(id);
            if (bytes != null && bytes.Length > 0)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
            }
            else
            {
                ToastService.Error("No se pudo descargar el backup");
            }
        }
        catch
        {
            ToastService.Error("Error al descargar el backup");
        }
        downloadingId = null;
    }

    private void ConfirmDelete(BackupDto backup)
    {
        backupToDelete = backup;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        backupToDelete = null;
    }

    private async Task DeleteBackup()
    {
        if (backupToDelete == null) return;

        showDeleteConfirm = false;
        deletingId = backupToDelete.Id;
        StateHasChanged();

        try
        {
            var result = await Api.DeleteBackupAsync(backupToDelete.Id);
            if (result)
            {
                ToastService.Success("Backup eliminado");
                await LoadData();
            }
            else
            {
                ToastService.Error("Error al eliminar el backup");
            }
        }
        catch
        {
            ToastService.Error("Error al eliminar el backup");
        }

        deletingId = null;
        backupToDelete = null;
    }

    private async Task SaveSchedule()
    {
        isSavingSchedule = true;
        try
        {
            var dto = new BackupScheduleDto
            {
                Enabled = scheduleEnabled,
                IntervalHours = scheduleIntervalHours,
                RetentionDays = scheduleRetentionDays
            };

            var result = await Api.UpdateBackupScheduleAsync(dto);
            if (result)
            {
                ToastService.Success("Programacion guardada");
            }
            else
            {
                ToastService.Error("Error al guardar la programacion");
            }
        }
        catch
        {
            ToastService.Error("Error al guardar la programacion");
        }
        isSavingSchedule = false;
    }
}
