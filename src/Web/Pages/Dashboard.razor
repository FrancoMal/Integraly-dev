@page "/"
@page "/index.html"
@attribute [Authorize]
@inject ApiClient Api
@inject AuthService AuthService

@if (isLoading)
{
    <p class="text-muted">Cargando...</p>
}
else if (userRole == "admin")
{
    <div class="dashboard-cards-row">
        <div class="stat-card">
            <div class="stat-card-icon primary">@SvgIcons.Users</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@adminStats?.TotalUsers</span>
                <span class="stat-card-label">Usuarios totales</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon info">@SvgIcons.User</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@adminStats?.TotalInstructors</span>
                <span class="stat-card-label">Instructores</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon success">@SvgIcons.Users</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@adminStats?.TotalStudents</span>
                <span class="stat-card-label">Estudiantes</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon warning">@SvgIcons.Calendar</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@adminStats?.TotalBookings</span>
                <span class="stat-card-label">Reservas totales</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon primary">@SvgIcons.CheckCircle</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@adminStats?.ActiveBookings</span>
                <span class="stat-card-label">Reservas activas</span>
            </div>
        </div>
    </div>

    @* Tabla de alumnos *@
    <div class="card" style="margin-top:1.5rem;">
        <div class="card-body">
            <h3 style="margin:0 0 1rem 0;font-size:1rem;">Resumen de alumnos</h3>
            @if (studentsSummary is null)
            {
                <p class="text-muted">Cargando...</p>
            }
            else if (studentsSummary.Count == 0)
            {
                <p class="text-muted">No hay alumnos registrados.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Alumno</th>
                                <th style="text-align:center;">Contratadas</th>
                                <th style="text-align:center;">Tomadas</th>
                                <th style="text-align:center;">Reservadas</th>
                                <th style="text-align:center;">Pendientes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in studentsSummary)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight:600;">@s.Name</div>
                                        <div style="font-size:0.75rem;color:var(--text-secondary);">@s.Username</div>
                                    </td>
                                    <td style="text-align:center;font-weight:600;">@s.TotalClasses</td>
                                    <td style="text-align:center;">
                                        <span class="status-badge status-active">@s.CompletedClasses</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <span class="status-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;">@s.ReservedClasses</span>
                                    </td>
                                    <td style="text-align:center;">
                                        @if (s.PendingClasses > 0)
                                        {
                                            <span class="status-badge" style="background:rgba(245,158,11,0.1);color:#f59e0b;">@s.PendingClasses</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">0</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else if (userRole == "instructor")
{
    <div class="dashboard-cards-row">
        <div class="stat-card">
            <div class="stat-card-icon primary">@SvgIcons.Calendar</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@instructorStats?.TotalBookings</span>
                <span class="stat-card-label">Reservas totales</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon success">@SvgIcons.Clock</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@instructorStats?.UpcomingBookings</span>
                <span class="stat-card-label">Proximas clases</span>
            </div>
        </div>
    </div>
}
else
{
    <div class="dashboard-cards-row">
        <div class="stat-card">
            <div class="stat-card-icon primary">@SvgIcons.Package</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@userStats?.RemainingTokens</span>
                <span class="stat-card-label">Clases disponibles</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon warning">@SvgIcons.Calendar</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@userStats?.UpcomingBookings</span>
                <span class="stat-card-label">Reservadas</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon success">@SvgIcons.CheckCircle</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@userStats?.UsedClasses</span>
                <span class="stat-card-label">Completadas</span>
            </div>
        </div>
    </div>

    @* Proxima clase destacada *@
    @if (nextClass is not null)
    {
        <div class="card" style="margin-top:1rem;border-left:4px solid #f59e0b;">
            <div class="card-body" style="padding:1rem 1.25rem;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
                    <div>
                        <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;color:#f59e0b;letter-spacing:0.5px;margin-bottom:0.4rem;">
                            <i class="fa-solid fa-bell" style="margin-right:0.3rem;"></i>Proxima clase
                        </div>
                        <div style="font-size:1.1rem;font-weight:700;margin-bottom:0.25rem;">
                            @nextClass.ScheduledDate.ToString("dddd dd 'de' MMMM", new System.Globalization.CultureInfo("es-AR"))
                        </div>
                        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;font-size:0.85rem;color:var(--text-secondary);">
                            <span><i class="fa-solid fa-clock" style="margin-right:0.3rem;"></i>@($"{nextClass.StartHour:00}:00 - {nextClass.StartHour + 1:00}:00")</span>
                            <span><i class="fa-solid fa-user" style="margin-right:0.3rem;"></i>@nextClass.InstructorName</span>
                            @{ var daysUntil = (nextClass.ScheduledDate.Date - DateTime.Today).Days; }
                            @if (daysUntil == 0)
                            {
                                <span class="status-badge" style="background:rgba(16,185,129,0.12);color:#10b981;font-weight:600;">Hoy</span>
                            }
                            else if (daysUntil == 1)
                            {
                                <span class="status-badge" style="background:rgba(245,158,11,0.12);color:#b45309;font-weight:600;">Manana</span>
                            }
                            else
                            {
                                <span class="status-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;">En @daysUntil dias</span>
                            }
                        </div>
                    </div>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        @if (!string.IsNullOrEmpty(nextClass.MeetLink))
                        {
                            <a href="@nextClass.MeetLink" target="_blank" class="btn btn-sm" style="background:#10b981;color:white;text-decoration:none;">
                                <i class="fa-solid fa-video" style="margin-right:0.3rem;"></i>Unirse a Meet
                            </a>
                        }
                        <a href="reservar" class="btn btn-sm btn-secondary" style="text-decoration:none;">
                            <i class="fa-solid fa-calendar-week" style="margin-right:0.3rem;"></i>Ver calendario
                        </a>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(nextClass.UserNotes))
                {
                    <div style="margin-top:0.75rem;padding:0.5rem 0.75rem;background:rgba(139,92,246,0.06);border-radius:6px;font-size:0.82rem;color:var(--text-secondary);">
                        <i class="fa-solid fa-sticky-note" style="margin-right:0.3rem;color:#8b5cf6;"></i>@nextClass.UserNotes
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card" style="margin-top:1rem;">
            <div class="card-body" style="padding:1.25rem;text-align:center;">
                <div style="font-size:2rem;margin-bottom:0.5rem;opacity:0.3;">
                    <i class="fa-solid fa-calendar-plus"></i>
                </div>
                <p style="color:var(--text-muted);margin-bottom:0.75rem;">No tenes clases reservadas</p>
                <a href="reservar" class="btn btn-primary btn-sm" style="text-decoration:none;">
                    <i class="fa-solid fa-plus" style="margin-right:0.3rem;"></i>Reservar una clase
                </a>
            </div>
        </div>
    }

    @* Ultimas clases *@
    @if (recentBookings is not null && recentBookings.Count > 0)
    {
        <div class="card" style="margin-top:1rem;">
            <div class="card-body" style="padding:0.75rem 1rem;">
                <h3 style="margin:0 0 0.75rem 0;font-size:0.95rem;">
                    <i class="fa-solid fa-history" style="margin-right:0.4rem;color:var(--text-muted);"></i>Ultimas clases
                </h3>
                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                    @foreach (var b in recentBookings)
                    {
                        var statusColor = b.Status switch { "completed" => "#3b82f6", "confirmed" => "#f59e0b", "cancelled" => "#ef4444", _ => "#64748b" };
                        var statusLabel = b.Status switch { "completed" => "Completada", "confirmed" => "Confirmada", "cancelled" => "Cancelada", _ => b.Status };
                        var statusIcon = b.Status switch { "completed" => "fa-circle-check", "confirmed" => "fa-calendar-check", "cancelled" => "fa-circle-xmark", _ => "fa-circle-question" };
                        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0.6rem;border-radius:8px;background:var(--bg-secondary);font-size:0.83rem;">
                            <i class="fa-solid @statusIcon" style="color:@statusColor;font-size:0.9rem;width:18px;text-align:center;"></i>
                            <div style="flex:1;min-width:0;">
                                <span style="font-weight:600;">@b.ScheduledDate.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-AR"))</span>
                                <span style="color:var(--text-muted);margin:0 0.3rem;">@($"{b.StartHour:00}:00")</span>
                                <span style="color:var(--text-secondary);">con @b.InstructorName</span>
                            </div>
                            <span style="font-size:0.72rem;color:@statusColor;font-weight:600;white-space:nowrap;">@statusLabel</span>
                        </div>
                    }
                </div>
                <div style="text-align:center;margin-top:0.75rem;">
                    <a href="reservar" style="font-size:0.8rem;color:var(--primary);text-decoration:none;">
                        Ver todas las reservas <i class="fa-solid fa-arrow-right" style="font-size:0.7rem;"></i>
                    </a>
                </div>
            </div>
        </div>
    }
}

@code {
    private string username = "usuario";
    private string userRole = "";
    private bool isLoading = true;

    private AdminDashboardDto? adminStats;
    private InstructorDashboardDto? instructorStats;
    private UserDashboardDto? userStats;
    private List<StudentSummaryDto>? studentsSummary;

    // User dashboard extras
    private BookingDto? nextClass;
    private List<BookingDto>? recentBookings;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            userRole = user.Role?.ToLower() ?? "";
        }

        try
        {
            if (userRole == "admin")
            {
                adminStats = await Api.GetAdminDashboardAsync();
                studentsSummary = await Api.GetStudentsSummaryAsync();
            }
            else if (userRole == "instructor")
            {
                instructorStats = await Api.GetInstructorDashboardAsync();
            }
            else
            {
                var statsTask = Api.GetUserDashboardAsync();
                var bookingsTask = Api.GetMyBookingsAsync();
                await Task.WhenAll(statsTask, bookingsTask);

                userStats = statsTask.Result;
                var allBookings = bookingsTask.Result ?? new();

                nextClass = allBookings
                    .Where(b => b.Status == "confirmed" && b.ScheduledDate.Date >= DateTime.Today)
                    .OrderBy(b => b.ScheduledDate).ThenBy(b => b.StartHour)
                    .FirstOrDefault();

                recentBookings = allBookings
                    .OrderByDescending(b => b.ScheduledDate).ThenByDescending(b => b.StartHour)
                    .Take(5)
                    .ToList();
            }
        }
        catch
        {
            // defaults
        }

        isLoading = false;
    }
}
