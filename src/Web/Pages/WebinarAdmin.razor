@page "/webinar-admin"
@attribute [Authorize]
@inject ApiClient Api
@inject IJSRuntime JS
@inject ToastService Toast
@inject NavigationManager Navigation

<div class="page-header">
    <h2 class="page-title">Webinar</h2>
</div>

@* Tabs *@
<div style="margin-bottom: 1rem;">
    <div class="view-toggle">
        <button class="btn btn-sm @(activeTab == "fechas" ? "btn-primary" : "btn-ghost")" @onclick='() => SwitchTab("fechas")'>
            <i class="fa-solid fa-calendar-days" style="margin-right:0.35rem;"></i>Fechas
        </button>
        <button class="btn btn-sm @(activeTab == "contactos" ? "btn-primary" : "btn-ghost")" @onclick='() => SwitchTab("contactos")'>
            <i class="fa-solid fa-address-book" style="margin-right:0.35rem;"></i>Contactos
        </button>
        <button class="btn btn-sm @(activeTab == "estadisticas" ? "btn-primary" : "btn-ghost")" @onclick='() => SwitchTab("estadisticas")'>
            <i class="fa-solid fa-chart-bar" style="margin-right:0.35rem;"></i>Estadisticas
        </button>
    </div>
</div>

@* ==================== TAB: FECHAS ==================== *@
@if (activeTab == "fechas")
{
    <div class="card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
            <h3>Fechas del Webinar (@(dates?.Count ?? 0))</h3>
            <button class="btn btn-primary" @onclick="ShowDateForm">
                <i class="fa-solid fa-plus" style="margin-right:0.3rem;"></i>Nueva Fecha
            </button>
        </div>
        <div class="card-body" style="padding: 0;">
            @if (isLoadingDates)
            {
                <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
            }
            else if (dates is null || !dates.Any())
            {
                <p class="text-muted" style="padding: 1.5rem;">No hay fechas configuradas</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Fecha</th>
                                <th>Link de reunion</th>
                                <th style="text-align:center;">Inscriptos</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in dates.OrderBy(x => x.Date))
                            {
                                <tr>
                                    <td><strong>@(string.IsNullOrEmpty(d.Name) ? "-" : d.Name)</strong></td>
                                    <td>@d.Date.ToString("dddd dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(d.MeetingLink))
                                        {
                                            <a href="@d.MeetingLink" target="_blank" style="word-break:break-all;font-size:0.82rem;">@d.MeetingLink</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        @if (d.RegistrationCount > 0)
                                        {
                                            <button class="btn btn-sm btn-ghost" style="font-weight:600;color:var(--primary);" @onclick="() => ShowRegistrations(d)" title="Ver inscriptos">
                                                @d.RegistrationCount <i class="fa-solid fa-eye" style="margin-left:0.25rem;font-size:0.7rem;"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center;">
                                            <button class="btn btn-sm btn-secondary" @onclick="() => ShowEditDate(d)" title="Editar">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteDate(d)" title="Eliminar">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ==================== TAB: CONTACTOS ==================== *@
@if (activeTab == "contactos")
{
    <div class="card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap:wrap; gap:0.5rem;">
            <h3>Contactos (@(filteredContacts?.Count ?? 0)@(contacts != null && filteredContacts != null && filteredContacts.Count != contacts.Count ? $" de {contacts.Count}" : ""))</h3>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                @if (selectedContactIds.Count > 0)
                {
                    <button class="btn btn-primary btn-sm" @onclick="ShowAssignModal">
                        <i class="fa-solid fa-paper-plane" style="margin-right:0.3rem;"></i>Invitar (@selectedContactIds.Count)
                    </button>
                }
                <button class="btn btn-secondary btn-sm" @onclick="ExportContacts" disabled="@(contacts is null || contacts.Count == 0)">
                    <i class="fa-solid fa-file-export" style="margin-right:0.3rem;"></i>Exportar Excel
                </button>
                <label class="btn btn-secondary btn-sm" style="cursor:pointer;margin:0;">
                    <i class="fa-solid fa-file-import" style="margin-right:0.3rem;"></i>Importar Excel
                    <InputFile OnChange="ImportContacts" style="display:none;" accept=".xlsx" />
                </label>
                <button class="btn btn-primary btn-sm" @onclick="ShowContactForm">
                    <i class="fa-solid fa-user-plus" style="margin-right:0.3rem;"></i>Nuevo Contacto
                </button>
            </div>
        </div>
        @* Filter bar *@
        @if (contacts != null && contacts.Any())
        {
            <div style="padding: 0.75rem 1rem; border-bottom: 1px solid var(--border-color, #e5e7eb); display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center;">
                <div style="display:flex;align-items:center;gap:0.4rem;">
                    <i class="fa-solid fa-filter" style="color:var(--text-secondary);font-size:0.8rem;"></i>
                    <select class="form-input" style="width:auto;min-width:140px;padding:0.3rem 0.5rem;font-size:0.85rem;" @bind="filterTag">
                        <option value="">Todos los tags</option>
                        @foreach (var tag in availableTags)
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>
                </div>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                    <select class="form-input" style="width:auto;min-width:140px;padding:0.3rem 0.5rem;font-size:0.85rem;" @bind="filterInscripto">
                        <option value="">Inscripto: Todos</option>
                        <option value="si">Inscripto: Si</option>
                        <option value="no">Inscripto: No</option>
                    </select>
                </div>
            </div>
        }
        <div class="card-body" style="padding: 0;">
            @if (isLoadingContacts)
            {
                <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
            }
            else if (contacts is null || !contacts.Any())
            {
                <p class="text-muted" style="padding: 1.5rem;">No hay contactos</p>
            }
            else if (filteredContacts != null && !filteredContacts.Any())
            {
                <p class="text-muted" style="padding: 1.5rem;">No hay contactos con ese filtro</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width:40px;text-align:center;">
                                    <input type="checkbox" @bind="selectAll" @bind:after="ToggleSelectAll" title="Seleccionar todos" />
                                </th>
                                <th>Nombre y Apellido</th>
                                <th>Email</th>
                                <th>Telefono</th>
                                <th>Empresa</th>
                                <th>Tag</th>
                                <th style="text-align:center;">Invitado</th>
                                <th style="text-align:center;">Inscripto</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in filteredContacts!)
                            {
                                <tr>
                                    <td style="text-align:center;">
                                        <input type="checkbox" checked="@selectedContactIds.Contains(c.Id)" @onchange="() => ToggleContactSelection(c.Id)" />
                                    </td>
                                    <td><strong>@c.FullName</strong></td>
                                    <td>@c.Email</td>
                                    <td>@(!string.IsNullOrEmpty(c.Phone) ? c.Phone : "-")</td>
                                    <td>@(!string.IsNullOrEmpty(c.Company) ? c.Company : "-")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(c.Tag))
                                        {
                                            <span style="background:var(--primary-light, #eef2ff);color:var(--primary, #4f46e5);padding:0.15rem 0.5rem;border-radius:12px;font-size:0.8rem;font-weight:600;">@c.Tag</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        @if (c.InvitedWebinarNames.Count > 0)
                                        {
                                            <span class="status-badge status-active" title="@string.Join("&#10;", c.InvitedWebinarNames)" style="cursor:help;">Si (@c.InvitedWebinarNames.Count)</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">No</span>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        @if (c.RegisteredWebinarNames.Count > 0)
                                        {
                                            <span class="status-badge status-active" title="@string.Join("&#10;", c.RegisteredWebinarNames)" style="cursor:help;">Si (@c.RegisteredWebinarNames.Count)</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">No</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.4rem;align-items:center;">
                                            <button class="btn btn-sm btn-secondary" @onclick="() => ShowContactHistory(c)" title="Historial">
                                                <i class="fa-solid fa-clock-rotate-left"></i>
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="() => ShowEditContact(c)" title="Editar">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="() => CopyContactLink(c.UUID)" title="Copiar link">
                                                <i class="fa-solid fa-copy"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteContact(c)" title="Eliminar">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ==================== TAB: ESTADISTICAS ==================== *@
@if (activeTab == "estadisticas")
{
    @if (isLoadingStats)
    {
        <p class="text-muted" style="padding: 1.5rem;">Cargando estadisticas...</p>
    }
    else if (stats is null)
    {
        <p class="text-muted" style="padding: 1.5rem;">No se pudieron cargar las estadisticas</p>
    }
    else
    {
        <div class="stats-grid" style="margin-bottom: 1.5rem;">
            <div class="stat-card">
                <div class="stat-card-icon primary">
                    <i class="fa-solid fa-address-book"></i>
                </div>
                <div class="stat-card-info">
                    <span class="stat-card-value">@stats.TotalContacts</span>
                    <span class="stat-card-label">Total Contactos</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-card-icon success">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <div class="stat-card-info">
                    <span class="stat-card-value">@stats.TotalRegistrations</span>
                    <span class="stat-card-label">Total Inscriptos</span>
                </div>
            </div>
        </div>

        @if (stats.PerDate.Any())
        {
            @foreach (var dateStat in stats.PerDate.OrderBy(x => x.Date))
            {
                <div class="card" style="margin-bottom: 1rem;">
                    <div class="card-header">
                        <h3><i class="fa-solid fa-calendar-day" style="margin-right:0.5rem;"></i>@(string.IsNullOrEmpty(dateStat.Name) ? dateStat.Date.ToString("dddd dd/MM/yyyy HH:mm") : $"{dateStat.Name} - {dateStat.Date.ToString("dddd dd/MM/yyyy HH:mm")}")</h3>
                    </div>
                    <div class="card-body">
                        <p style="margin-bottom: 1rem;"><strong>Inscriptos:</strong> @dateStat.Registrations</p>

                        @if (dateStat.Registrations > 0)
                        {
                            <h4 style="margin-bottom: 0.75rem; font-size: 0.95rem; color: var(--text-secondary);">Herramientas de IA conocidas</h4>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
                                @foreach (var tool in GetAiToolStats(dateStat))
                                {
                                    var pct = dateStat.Registrations > 0 ? (int)Math.Round(100.0 * tool.Count / dateStat.Registrations) : 0;
                                    <div>
                                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.25rem;">
                                            <span style="font-weight:600;font-size:0.9rem;">@tool.Name</span>
                                            <span style="font-size:0.85rem;color:var(--text-secondary);">@pct% (@tool.Count/@dateStat.Registrations)</span>
                                        </div>
                                        <div style="background:var(--bg-secondary, #e5e7eb);border-radius:6px;height:8px;overflow:hidden;">
                                            <div style="background:var(--primary, #4f46e5);height:100%;width:@(pct)%;border-radius:6px;transition:width 0.3s;"></div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <h4 style="margin-bottom: 0.75rem; font-size: 0.95rem; color: var(--text-secondary);">Conocimiento de Vibe Coding</h4>
                            <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
                                @foreach (var vc in dateStat.VibeCodingBreakdown)
                                {
                                    <div style="background:var(--bg-secondary, #f3f4f6);border-radius:8px;padding:0.5rem 1rem;text-align:center;">
                                        <div style="font-weight:700;font-size:1.1rem;color:var(--text-primary);">@vc.Value</div>
                                        <div style="font-size:0.8rem;color:var(--text-secondary);">@GetVibeCodingLabel(vc.Key)</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">No hay datos por fecha todavia</p>
        }
    }
}

@* ==================== MODAL: NUEVA/EDITAR FECHA ==================== *@
@if (showDateModal)
{
    <div class="modal-overlay" @onclick="CloseDateForm">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingDate is not null ? "Editar Fecha" : "Nueva Fecha de Webinar")</h3>
                <button class="btn-close" @onclick="CloseDateForm">&times;</button>
            </div>
            <div class="modal-body" style="max-height:70vh;overflow-y:auto;">
                @if (!string.IsNullOrEmpty(dateFormError))
                {
                    <div class="form-error">@dateFormError</div>
                }
                <div class="form-group">
                    <label class="form-label">Nombre del webinar</label>
                    <input class="form-input" type="text" @bind="formDateName" placeholder="Ej: Webinar IA para empresas" />
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha y hora</label>
                    <input class="form-input" type="datetime-local" @bind="formDate" />
                </div>
                <div class="form-group">
                    <label class="form-label">Link de reunion (opcional)</label>
                    <input class="form-input" type="url" @bind="formMeetingLink" placeholder="https://meet.google.com/..." />
                </div>

                <hr style="margin:1rem 0;border-color:var(--border-color, #e5e7eb);" />
                <h4 style="margin-bottom:0.75rem;font-size:0.95rem;color:var(--text-secondary);">
                    <i class="fa-solid fa-envelope" style="margin-right:0.3rem;"></i>Configuracion de invitacion
                </h4>

                <div class="form-group">
                    <label class="form-label">Asunto del email</label>
                    <input class="form-input" type="text" @bind="formInviteSubject" placeholder="Ej: Te invitamos al webinar {{webinar}}" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mensaje de invitacion (HTML para email / texto para WhatsApp)</label>
                    <textarea class="form-input" rows="8" @bind="formInviteMessage" placeholder="Hola {{nombre}}, te invitamos a participar...

Variables disponibles: {{nombre}}, {{email}}, {{link}}, {{webinar}}, {{fecha}}"></textarea>
                </div>
                <div style="display:flex;gap:1.5rem;margin-top:0.5rem;">
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <input type="checkbox" @bind="formSendByEmail" />
                        <i class="fa-solid fa-envelope" style="color:var(--primary);"></i> Enviar por Email
                    </label>
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <input type="checkbox" @bind="formSendByWhatsapp" />
                        <i class="fa-brands fa-whatsapp" style="color:#25D366;"></i> Enviar por WhatsApp
                    </label>
                </div>
                @if (formSendByWhatsapp)
                {
                    <p style="margin-top:0.5rem;font-size:0.8rem;color:var(--text-secondary);"><i class="fa-solid fa-info-circle"></i> WhatsApp se va a implementar proximamente</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDateForm">
                    <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                </button>
                <button class="btn btn-primary" @onclick="SaveDate" disabled="@isSaving">
                    <i class="fa-solid fa-floppy-disk" style="margin-right:0.3rem;"></i>@(isSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: INSCRIPTOS ==================== *@
@if (showRegistrationsModal && registrationsDate is not null)
{
    <div class="modal-overlay" @onclick="() => showRegistrationsModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:600px;">
            <div class="modal-header">
                <h3><i class="fa-solid fa-users" style="margin-right:0.5rem;"></i>Inscriptos - @(string.IsNullOrEmpty(registrationsDate.Name) ? registrationsDate.Date.ToString("dd/MM/yyyy HH:mm") : $"{registrationsDate.Name} ({registrationsDate.Date.ToString("dd/MM/yyyy HH:mm")})")</h3>
                <button class="btn-close" @onclick="() => showRegistrationsModal = false">&times;</button>
            </div>
            <div class="modal-body" style="padding:0;">
                @if (dateRegistrations is null)
                {
                    <p class="text-muted" style="padding:1.5rem;">Cargando...</p>
                }
                else if (dateRegistrations.Count == 0)
                {
                    <p class="text-muted" style="padding:1.5rem;">No hay inscriptos</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Email</th>
                                    <th>Telefono</th>
                                    <th>Empresa</th>
                                    <th>Fecha registro</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in dateRegistrations)
                                {
                                    <tr>
                                        <td><strong>@r.FullName</strong></td>
                                        <td>@r.Email</td>
                                        <td>@(!string.IsNullOrEmpty(r.Phone) ? r.Phone : "-")</td>
                                        <td>@(!string.IsNullOrEmpty(r.Company) ? r.Company : "-")</td>
                                        <td style="font-size:0.82rem;">@r.RegisteredAt.ToString("dd/MM/yy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showRegistrationsModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: NUEVO/EDITAR CONTACTO ==================== *@
@if (showContactModal)
{
    <div class="modal-overlay" @onclick="CloseContactForm">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingContact is not null ? "Editar Contacto" : "Nuevo Contacto")</h3>
                <button class="btn-close" @onclick="CloseContactForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(contactFormError))
                {
                    <div class="form-error">@contactFormError</div>
                }
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" @bind="formEmail" placeholder="correo@ejemplo.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">Nombre y Apellido</label>
                    <input class="form-input" type="text" @bind="formFullName" placeholder="Juan Perez" />
                </div>
                <div class="form-group">
                    <label class="form-label">Telefono (opcional)</label>
                    <input class="form-input" type="tel" @bind="formPhone" placeholder="+54 11 1234-5678" />
                </div>
                <div class="form-group">
                    <label class="form-label">Empresa (opcional)</label>
                    <input class="form-input" type="text" @bind="formCompany" placeholder="Nombre de la empresa" />
                </div>
                <div class="form-group">
                    <label class="form-label">Tag (opcional)</label>
                    <input class="form-input" type="text" @bind="formTag" placeholder="Ej: VIP, Evento2024, Partner" list="tag-suggestions" />
                    <datalist id="tag-suggestions">
                        @foreach (var tag in availableTags)
                        {
                            <option value="@tag" />
                        }
                    </datalist>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseContactForm">
                    <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                </button>
                <button class="btn btn-primary" @onclick="SaveContact" disabled="@isSaving">
                    <i class="fa-solid fa-floppy-disk" style="margin-right:0.3rem;"></i>@(isSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: ASIGNAR WEBINAR ==================== *@
@if (showAssignModal)
{
    <div class="modal-overlay" @onclick="() => showAssignModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><i class="fa-solid fa-paper-plane" style="margin-right:0.5rem;"></i>Invitar a Webinar</h3>
                <button class="btn-close" @onclick="() => showAssignModal = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom:1rem;">Se invitaran <strong>@selectedContactIds.Count contactos</strong> al webinar seleccionado.</p>
                @if (!string.IsNullOrEmpty(assignError))
                {
                    <div class="form-error">@assignError</div>
                }
                <div class="form-group">
                    <label class="form-label">Seleccionar webinar</label>
                    <select class="form-input" @bind="assignWebinarDateId">
                        <option value="0" disabled>Elegir webinar...</option>
                        @if (dates != null)
                        {
                            @foreach (var d in dates.OrderBy(x => x.Date))
                            {
                                <option value="@d.Id">@(string.IsNullOrEmpty(d.Name) ? d.Date.ToString("dd/MM/yyyy HH:mm") : $"{d.Name} - {d.Date.ToString("dd/MM/yyyy HH:mm")}")</option>
                            }
                        }
                    </select>
                </div>
                @if (assignWebinarDateId > 0)
                {
                    var selectedWebinar = dates?.FirstOrDefault(d => d.Id == assignWebinarDateId);
                    if (selectedWebinar != null)
                    {
                        <div style="background:var(--bg-secondary, #f3f4f6);border-radius:8px;padding:0.75rem;margin-top:0.5rem;font-size:0.85rem;">
                            <div style="margin-bottom:0.4rem;"><strong>Se enviara por:</strong></div>
                            <div style="display:flex;gap:1rem;">
                                @if (selectedWebinar.SendByEmail)
                                {
                                    <span><i class="fa-solid fa-envelope" style="color:var(--primary);margin-right:0.25rem;"></i>Email</span>
                                }
                                @if (selectedWebinar.SendByWhatsapp)
                                {
                                    <span><i class="fa-brands fa-whatsapp" style="color:#25D366;margin-right:0.25rem;"></i>WhatsApp</span>
                                }
                                @if (!selectedWebinar.SendByEmail && !selectedWebinar.SendByWhatsapp)
                                {
                                    <span class="text-muted">Solo asignacion (sin notificacion)</span>
                                }
                            </div>
                            @if (string.IsNullOrWhiteSpace(selectedWebinar.InviteMessage) && (selectedWebinar.SendByEmail || selectedWebinar.SendByWhatsapp))
                            {
                                <div style="color:var(--danger, #dc2626);margin-top:0.4rem;">
                                    <i class="fa-solid fa-triangle-exclamation"></i> No hay mensaje configurado. Edita el webinar para agregar el mensaje de invitacion.
                                </div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showAssignModal = false">
                    <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                </button>
                <button class="btn btn-primary" @onclick="AssignContacts" disabled="@(isSaving || assignWebinarDateId == 0)">
                    <i class="fa-solid fa-paper-plane" style="margin-right:0.3rem;"></i>@(isSaving ? "Enviando..." : "Enviar invitacion")
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: CONFIRMAR ELIMINACION FECHA ==================== *@
@if (showDeleteDateConfirm)
{
    <div class="modal-overlay" @onclick="() => showDeleteDateConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirmar eliminacion</h3>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar la fecha <strong>@dateToDelete?.Date.ToString("dd/MM/yyyy HH:mm")</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteDateConfirm = false">
                    <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                </button>
                <button class="btn btn-danger" @onclick="DeleteDate">
                    <i class="fa-solid fa-trash" style="margin-right:0.3rem;"></i>Eliminar
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: CONFIRMAR ELIMINACION CONTACTO ==================== *@
@if (showDeleteContactConfirm)
{
    <div class="modal-overlay" @onclick="() => showDeleteContactConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirmar eliminacion</h3>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar el contacto <strong>@contactToDelete?.FullName</strong> (@contactToDelete?.Email)?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteContactConfirm = false">
                    <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                </button>
                <button class="btn btn-danger" @onclick="DeleteContact">
                    <i class="fa-solid fa-trash" style="margin-right:0.3rem;"></i>Eliminar
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: HISTORIAL CONTACTO ==================== *@
@if (showHistoryModal && historyContact is not null)
{
    <div class="modal-overlay" @onclick="() => showHistoryModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:650px;">
            <div class="modal-header">
                <h3><i class="fa-solid fa-clock-rotate-left" style="margin-right:0.5rem;"></i>Historial - @historyContact.FullName</h3>
                <button class="btn-close" @onclick="() => showHistoryModal = false">&times;</button>
            </div>
            <div class="modal-body" style="padding:0;max-height:60vh;overflow-y:auto;">
                @if (contactHistory is null)
                {
                    <p class="text-muted" style="padding:1.5rem;">Cargando...</p>
                }
                else if (contactHistory.Count == 0)
                {
                    <p class="text-muted" style="padding:1.5rem;">No hay eventos registrados para este contacto</p>
                }
                else
                {
                    <div style="padding:1rem;">
                        @foreach (var h in contactHistory)
                        {
                            <div style="display:flex;gap:0.75rem;padding:0.6rem 0;border-bottom:1px solid var(--border-color, #e5e7eb);">
                                <div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;@GetHistoryIconStyle(h.Action)">
                                    <i class="@GetHistoryIcon(h.Action)"></i>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.2rem;">
                                        <span style="font-weight:600;font-size:0.85rem;">@GetHistoryLabel(h.Action)</span>
                                        <span style="font-size:0.75rem;color:var(--text-secondary);white-space:nowrap;">@h.CreatedAt.ToString("dd/MM/yy HH:mm")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(h.Changes))
                                    {
                                        <p style="margin:0;font-size:0.82rem;color:var(--text-secondary);word-break:break-word;">@h.Changes</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showHistoryModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    private string activeTab = "fechas";

    // Dates
    private List<WebinarDateDto>? dates;
    private bool isLoadingDates = true;
    private bool showDateModal;
    private WebinarDateDto? editingDate;
    private string formDateName = "";
    private DateTime formDate = DateTime.Now;
    private string formMeetingLink = "";
    private string formInviteSubject = "";
    private string formInviteMessage = "";
    private bool formSendByEmail;
    private bool formSendByWhatsapp;
    private string? dateFormError;
    private WebinarDateDto? dateToDelete;
    private bool showDeleteDateConfirm;

    // Registrations modal
    private bool showRegistrationsModal;
    private WebinarDateDto? registrationsDate;
    private List<WebinarRegistrationDto>? dateRegistrations;

    // Contacts
    private List<WebinarContactDto>? contacts;
    private bool isLoadingContacts = true;
    private bool showContactModal;
    private WebinarContactDto? editingContact;
    private string formEmail = "";
    private string formFullName = "";
    private string formPhone = "";
    private string formCompany = "";
    private string formTag = "";
    private string? contactFormError;
    private WebinarContactDto? contactToDelete;
    private bool showDeleteContactConfirm;

    // History modal
    private bool showHistoryModal;
    private WebinarContactDto? historyContact;
    private List<ContactHistoryDto>? contactHistory;

    // Selection & assign
    private HashSet<int> selectedContactIds = new();
    private bool selectAll;
    private bool showAssignModal;
    private int assignWebinarDateId;
    private string? assignError;

    // Filters
    private string _filterTag = "";
    private string filterTag { get => _filterTag; set { _filterTag = value; selectedContactIds.Clear(); selectAll = false; } }
    private string _filterInscripto = "";
    private string filterInscripto { get => _filterInscripto; set { _filterInscripto = value; selectedContactIds.Clear(); selectAll = false; } }

    private List<string> availableTags => contacts?
        .Where(c => !string.IsNullOrEmpty(c.Tag))
        .Select(c => c.Tag!)
        .Distinct()
        .OrderBy(t => t)
        .ToList() ?? new();

    private List<WebinarContactDto>? filteredContacts => contacts?
        .Where(c => string.IsNullOrEmpty(filterTag) || c.Tag == filterTag)
        .Where(c => string.IsNullOrEmpty(filterInscripto)
            || (filterInscripto == "si" && c.RegisteredWebinarNames.Count > 0)
            || (filterInscripto == "no" && c.RegisteredWebinarNames.Count == 0))
        .OrderByDescending(c => c.CreatedAt)
        .ToList();

    // Stats
    private WebinarStatsDto? stats;
    private bool isLoadingStats = true;

    // Shared
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadDates();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "fechas" && dates is null)
            await LoadDates();
        else if (tab == "contactos" && contacts is null)
            await LoadContacts();
        else if (tab == "estadisticas")
            await LoadStats();
    }

    // ==================== DATES ====================

    private async Task LoadDates()
    {
        isLoadingDates = true;
        try
        {
            dates = await Api.GetWebinarDatesAsync();
        }
        catch
        {
            Toast.Error("Error al cargar las fechas");
        }
        isLoadingDates = false;
    }

    private void ShowDateForm()
    {
        editingDate = null;
        formDateName = "";
        formDate = DateTime.Now.AddDays(7).Date.AddHours(10);
        formMeetingLink = "";
        formInviteSubject = "";
        formInviteMessage = "";
        formSendByEmail = false;
        formSendByWhatsapp = false;
        dateFormError = null;
        showDateModal = true;
    }

    private void ShowEditDate(WebinarDateDto d)
    {
        editingDate = d;
        formDateName = d.Name ?? "";
        formDate = d.Date;
        formMeetingLink = d.MeetingLink ?? "";
        formInviteSubject = d.InviteSubject ?? "";
        formInviteMessage = d.InviteMessage ?? "";
        formSendByEmail = d.SendByEmail;
        formSendByWhatsapp = d.SendByWhatsapp;
        dateFormError = null;
        showDateModal = true;
    }

    private void CloseDateForm()
    {
        showDateModal = false;
        editingDate = null;
        dateFormError = null;
    }

    private async Task SaveDate()
    {
        dateFormError = null;
        isSaving = true;
        try
        {
            var request = new CreateWebinarDateRequest
            {
                Name = formDateName?.Trim() ?? "",
                Date = formDate,
                MeetingLink = string.IsNullOrWhiteSpace(formMeetingLink) ? null : formMeetingLink.Trim(),
                InviteSubject = string.IsNullOrWhiteSpace(formInviteSubject) ? null : formInviteSubject.Trim(),
                InviteMessage = string.IsNullOrWhiteSpace(formInviteMessage) ? null : formInviteMessage,
                SendByEmail = formSendByEmail,
                SendByWhatsapp = formSendByWhatsapp
            };

            if (editingDate is not null)
            {
                var result = await Api.UpdateWebinarDateAsync(editingDate.Id, request);
                if (result is not null)
                {
                    Toast.Success("Fecha actualizada");
                    showDateModal = false;
                    editingDate = null;
                    await LoadDates();
                }
                else
                {
                    dateFormError = "Error al actualizar la fecha";
                }
            }
            else
            {
                var result = await Api.CreateWebinarDateAsync(request);
                if (result is not null)
                {
                    Toast.Success("Fecha creada exitosamente");
                    showDateModal = false;
                    await LoadDates();
                }
                else
                {
                    dateFormError = "Error al crear la fecha";
                }
            }
        }
        catch
        {
            dateFormError = "Error al guardar la fecha";
        }
        isSaving = false;
    }

    private async Task ShowRegistrations(WebinarDateDto d)
    {
        registrationsDate = d;
        dateRegistrations = null;
        showRegistrationsModal = true;
        StateHasChanged();

        try
        {
            dateRegistrations = await Api.GetDateRegistrationsAsync(d.Id);
        }
        catch
        {
            Toast.Error("Error al cargar inscriptos");
        }
        StateHasChanged();
    }

    private void ConfirmDeleteDate(WebinarDateDto d)
    {
        dateToDelete = d;
        showDeleteDateConfirm = true;
    }

    private async Task DeleteDate()
    {
        if (dateToDelete is null) return;
        var ok = await Api.DeleteWebinarDateAsync(dateToDelete.Id);
        if (ok)
        {
            Toast.Success("Fecha eliminada");
            await LoadDates();
        }
        else
        {
            Toast.Error("Error al eliminar la fecha");
        }
        showDeleteDateConfirm = false;
        dateToDelete = null;
    }

    // ==================== CONTACTS ====================

    private async Task LoadContacts()
    {
        isLoadingContacts = true;
        selectedContactIds.Clear();
        selectAll = false;
        try
        {
            contacts = await Api.GetWebinarContactsAsync();
            if (dates is null)
                dates = await Api.GetWebinarDatesAsync();
        }
        catch
        {
            Toast.Error("Error al cargar los contactos");
        }
        isLoadingContacts = false;
    }

    private void ShowContactForm()
    {
        editingContact = null;
        formEmail = "";
        formFullName = "";
        formPhone = "";
        formCompany = "";
        formTag = "";
        contactFormError = null;
        showContactModal = true;
    }

    private void ShowEditContact(WebinarContactDto c)
    {
        editingContact = c;
        formEmail = c.Email;
        formFullName = c.FullName;
        formPhone = c.Phone ?? "";
        formCompany = c.Company ?? "";
        formTag = c.Tag ?? "";
        contactFormError = null;
        showContactModal = true;
    }

    private void CloseContactForm()
    {
        showContactModal = false;
        editingContact = null;
        contactFormError = null;
    }

    private async Task SaveContact()
    {
        contactFormError = null;
        if (string.IsNullOrWhiteSpace(formEmail))
        {
            contactFormError = "El email es obligatorio";
            return;
        }
        if (string.IsNullOrWhiteSpace(formFullName))
        {
            contactFormError = "El nombre y apellido es obligatorio";
            return;
        }

        isSaving = true;
        try
        {
            if (editingContact is not null)
            {
                var request = new UpdateWebinarContactRequest
                {
                    Email = formEmail.Trim(),
                    FullName = formFullName.Trim(),
                    Phone = string.IsNullOrWhiteSpace(formPhone) ? null : formPhone.Trim(),
                    Company = string.IsNullOrWhiteSpace(formCompany) ? null : formCompany.Trim(),
                    Tag = string.IsNullOrWhiteSpace(formTag) ? null : formTag.Trim()
                };
                var result = await Api.UpdateWebinarContactAsync(editingContact.Id, request);
                if (result is not null)
                {
                    Toast.Success("Contacto actualizado");
                    showContactModal = false;
                    editingContact = null;
                    await LoadContacts();
                }
                else
                {
                    contactFormError = "Error al actualizar el contacto";
                }
            }
            else
            {
                var request = new CreateWebinarContactRequest
                {
                    Email = formEmail.Trim(),
                    FullName = formFullName.Trim(),
                    Phone = string.IsNullOrWhiteSpace(formPhone) ? null : formPhone.Trim(),
                    Company = string.IsNullOrWhiteSpace(formCompany) ? null : formCompany.Trim(),
                    Tag = string.IsNullOrWhiteSpace(formTag) ? null : formTag.Trim()
                };
                var result = await Api.CreateWebinarContactAsync(request);
                if (result is not null)
                {
                    Toast.Success("Contacto creado exitosamente");
                    showContactModal = false;
                    await LoadContacts();
                }
                else
                {
                    contactFormError = "Error al crear el contacto. Puede que el email ya exista.";
                }
            }
        }
        catch
        {
            contactFormError = "Error al guardar el contacto";
        }
        isSaving = false;
    }

    // ==================== HISTORY ====================

    private async Task ShowContactHistory(WebinarContactDto c)
    {
        historyContact = c;
        contactHistory = null;
        showHistoryModal = true;
        StateHasChanged();

        try
        {
            contactHistory = await Api.GetWebinarContactHistoryAsync(c.Id);
        }
        catch
        {
            Toast.Error("Error al cargar el historial");
        }
        StateHasChanged();
    }

    private string GetHistoryIcon(string action) => action switch
    {
        "create" => "fa-solid fa-user-plus",
        "update" => "fa-solid fa-pen",
        "delete" => "fa-solid fa-trash",
        "email_sent" => "fa-solid fa-envelope-circle-check",
        "email_failed" => "fa-solid fa-envelope-circle-xmark",
        "whatsapp_pending" => "fa-brands fa-whatsapp",
        "bulk_invite" => "fa-solid fa-paper-plane",
        _ => "fa-solid fa-circle-info"
    };

    private string GetHistoryIconStyle(string action) => action switch
    {
        "create" => "background:#dcfce7;color:#16a34a;",
        "update" => "background:#dbeafe;color:#2563eb;",
        "delete" => "background:#fee2e2;color:#dc2626;",
        "email_sent" => "background:#dcfce7;color:#16a34a;",
        "email_failed" => "background:#fee2e2;color:#dc2626;",
        "whatsapp_pending" => "background:#d1fae5;color:#25D366;",
        "bulk_invite" => "background:#eef2ff;color:#4f46e5;",
        _ => "background:#f3f4f6;color:#6b7280;"
    };

    private string GetHistoryLabel(string action) => action switch
    {
        "create" => "Contacto creado",
        "update" => "Contacto editado",
        "delete" => "Contacto eliminado",
        "email_sent" => "Email enviado",
        "email_failed" => "Email fallido",
        "whatsapp_pending" => "WhatsApp pendiente",
        "bulk_invite" => "Invitacion masiva",
        _ => action
    };

    // ==================== SELECTION & ASSIGN ====================

    private void ToggleContactSelection(int id)
    {
        if (!selectedContactIds.Remove(id))
            selectedContactIds.Add(id);
        selectAll = filteredContacts != null && filteredContacts.All(c => selectedContactIds.Contains(c.Id));
    }

    private void ToggleSelectAll()
    {
        if (filteredContacts is null) return;
        if (selectAll)
        {
            foreach (var c in filteredContacts)
                selectedContactIds.Add(c.Id);
        }
        else
        {
            foreach (var c in filteredContacts)
                selectedContactIds.Remove(c.Id);
        }
    }

    private async Task ShowAssignModal()
    {
        assignError = null;
        assignWebinarDateId = 0;
        if (dates is null)
            dates = await Api.GetWebinarDatesAsync();
        showAssignModal = true;
    }

    private async Task AssignContacts()
    {
        if (assignWebinarDateId == 0)
        {
            assignError = "Selecciona un webinar";
            return;
        }

        isSaving = true;
        try
        {
            var request = new AssignWebinarRequest
            {
                ContactIds = selectedContactIds.ToList(),
                WebinarDateId = assignWebinarDateId
            };
            var result = await Api.AssignContactsToWebinarAsync(request);
            if (result is not null)
            {
                Toast.Success(result.Message);
                showAssignModal = false;
                selectedContactIds.Clear();
                selectAll = false;
                await LoadContacts();
            }
            else
            {
                assignError = "Error al asignar contactos";
            }
        }
        catch
        {
            assignError = "Error al asignar contactos";
        }
        isSaving = false;
    }

    private async Task CopyContactLink(string uuid)
    {
        try
        {
            var uri = new Uri(Navigation.BaseUri);
            var origin = $"{uri.Scheme}://{uri.Authority}";
            var url = $"{origin}/webinar/{uuid}";
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
            Toast.Success("Link copiado al portapapeles");
        }
        catch
        {
            Toast.Error("No se pudo copiar el link");
        }
    }

    private async Task ExportContacts()
    {
        if (contacts is null || contacts.Count == 0) return;

        try
        {
            var bytes = await Api.ExportWebinarContactsAsync();
            if (bytes is null || bytes.Length == 0)
            {
                Toast.Error("Error al exportar contactos");
                return;
            }

            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval", $"{{ var a=document.createElement('a'); a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}'; a.download='contactos_webinar.xlsx'; a.click(); }}");

            Toast.Success("Contactos exportados");
        }
        catch
        {
            Toast.Error("Error al exportar contactos");
        }
    }

    private async Task ImportContacts(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        if (file.Size > 2 * 1024 * 1024)
        {
            Toast.Error("El archivo no puede superar 2 MB");
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(2 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            var result = await Api.ImportWebinarContactsFileAsync(fileBytes, file.Name);
            if (result is not null)
            {
                Toast.Success(result.Message);
                await LoadContacts();
            }
            else
            {
                Toast.Error("Error al importar contactos");
            }
        }
        catch
        {
            Toast.Error("Error al leer el archivo. Asegurate de que sea un Excel valido (.xlsx)");
        }
    }

    private void ConfirmDeleteContact(WebinarContactDto c)
    {
        contactToDelete = c;
        showDeleteContactConfirm = true;
    }

    private async Task DeleteContact()
    {
        if (contactToDelete is null) return;
        var ok = await Api.DeleteWebinarContactAsync(contactToDelete.Id);
        if (ok)
        {
            Toast.Success("Contacto eliminado");
            await LoadContacts();
        }
        else
        {
            Toast.Error("Error al eliminar el contacto");
        }
        showDeleteContactConfirm = false;
        contactToDelete = null;
    }

    // ==================== STATS ====================

    private async Task LoadStats()
    {
        isLoadingStats = true;
        try
        {
            stats = await Api.GetWebinarStatsAsync();
        }
        catch
        {
            Toast.Error("Error al cargar las estadisticas");
        }
        isLoadingStats = false;
    }

    private List<(string Name, int Count)> GetAiToolStats(WebinarDateStatsDto dateStat)
    {
        return new List<(string Name, int Count)>
        {
            ("ChatGPT", dateStat.KnowsChatGPT),
            ("Claude", dateStat.KnowsClaude),
            ("Gemini", dateStat.KnowsGemini),
            ("Copilot", dateStat.KnowsCopilot),
            ("Perplexity", dateStat.KnowsPerplexity),
            ("Grok", dateStat.KnowsGrok),
            ("DeepSeek", dateStat.KnowsDeepSeek)
        }.OrderByDescending(x => x.Count).ToList();
    }

    private string GetVibeCodingLabel(string key)
    {
        return key switch
        {
            "yes_use_it" => "Si, lo usa",
            "yes_not_tried" => "Si, pero no lo probo",
            "no_idea" => "No sabe que es",
            _ => key
        };
    }
}
