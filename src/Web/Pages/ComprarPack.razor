@page "/comprar"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (isLoading)
{
    <div class="card"><div class="card-body"><p class="text-muted">Cargando planes...</p></div></div>
}
else
{
    @if (isPayPal)
    {
        <div class="payment-method-selector">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            <span>Precios en <strong>USD</strong> - Pago con <strong>PayPal</strong></span>
        </div>
    }

    <div class="pricing-grid">
        @foreach (var plan in plans)
        {
            var basePrice = isPayPal ? plan.PriceUSD : plan.Price;
            var pricePerClass = plan.Classes > 0 ? basePrice / plan.Classes : 0;
            var singleBase = isPayPal
                ? (plans.FirstOrDefault(p => p.Classes == 1)?.PriceUSD ?? basePrice)
                : (plans.FirstOrDefault(p => p.Classes == 1)?.Price ?? basePrice);
            var savingsPercent = singleBase > 0 && plan.Classes > 1
                ? (int)Math.Round((1 - (double)(pricePerClass / singleBase)) * 100)
                : 0;
            var currSymbol = isPayPal ? "US$" : "$";

            <div class="pricing-card @(plan.IsPopular ? "pricing-card-popular" : "")">
                @if (plan.IsPopular)
                {
                    <div class="pricing-badge">Mas popular</div>
                }
                <div class="pricing-header">
                    <h3 class="pricing-name">@plan.Name</h3>
                    <div class="pricing-classes">@plan.Classes @(plan.Classes == 1 ? "clase" : "clases")</div>
                </div>
                <div class="pricing-body">
                    <div class="pricing-price">@currSymbol@FormatPrice(basePrice, isPayPal)</div>
                    @if (!isPayPal)
                    {
                        <div style="font-size:0.75rem;color:var(--text-muted);margin-top:-0.25rem;line-height:1.3;">
                            Precio en pesos argentinos<br/>No incluye IVA
                        </div>
                    }
                    <div class="pricing-per-class">@currSymbol@FormatPrice(pricePerClass, isPayPal) por clase</div>
                    @if (savingsPercent > 0)
                    {
                        <div class="pricing-savings">Ahorra @savingsPercent%</div>
                    }
                </div>
                <div class="pricing-footer">
                    @if (isPayPal)
                    {
                        <button class="btn btn-primary pricing-btn @(plan.IsPopular ? "pricing-btn-popular" : "")"
                                disabled="@(processingPlanId == plan.Id)"
                                @onclick="() => ComprarPlan(plan)">
                            @if (processingPlanId == plan.Id)
                            {
                                <span>Procesando...</span>
                            }
                            else
                            {
                                <span><i class="fa-brands fa-paypal" style="margin-right:0.3rem;"></i>Pagar con PayPal</span>
                            }
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary pricing-btn @(plan.IsPopular ? "pricing-btn-popular" : "")"
                                @onclick="() => OpenCheckoutModal(plan)">
                            <i class="fa-solid fa-cart-shopping" style="margin-right:0.3rem;"></i>Comprar
                        </button>
                    }
                </div>
            </div>
        }
    </div>

    @if (payments is not null && payments.Count > 0)
    {
        <div class="card" style="margin-top: 2rem;">
            <div class="card-body">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Historial de pagos</h3>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Plan</th>
                                <th style="text-align:center;">Clases</th>
                                <th style="text-align:right;">Monto</th>
                                <th style="text-align:center;">Estado</th>
                                <th>Fecha</th>
                                <th style="text-align:center;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in payments)
                            {
                                var isPending = payment.Status?.ToLower() is "pending" or "pendiente";
                                var currencySymbol = payment.Currency == "USD" ? "US$" : "$";
                                var isUsd = payment.Currency == "USD";
                                <tr>
                                    <td><strong>@payment.PlanName</strong></td>
                                    <td style="text-align:center;">@payment.Classes</td>
                                    <td style="text-align:right;">@currencySymbol@FormatPrice(payment.Amount, isUsd)</td>
                                    <td style="text-align:center;">
                                        <span class="status-badge @GetStatusClass(payment.Status)">
                                            @GetStatusLabel(payment.Status)
                                        </span>
                                    </td>
                                    <td>@payment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="text-align:center;">
                                        @{
                                            var isTransfer = payment.PaymentProvider == "transferencia";
                                            var isPendingReview = payment.Status?.ToLower() == "pending_review";
                                        }
                                        @if (isPending && isTransfer)
                                        {
                                            <div style="display:flex;gap:0.4rem;justify-content:center;flex-wrap:wrap;">
                                                <label class="btn btn-sm btn-primary" style="cursor:pointer;margin:0;" title="Adjuntar comprobante">
                                                    <i class="fa-solid fa-paperclip"></i> Comprobante
                                                    <InputFile OnChange="e => UploadReceipt(e, payment)" style="display:none;" accept=".jpg,.jpeg,.png,.pdf" />
                                                </label>
                                                <button class="btn btn-sm btn-danger" title="Eliminar"
                                                        disabled="@(deletingPaymentId == payment.Id)"
                                                        @onclick="() => ConfirmDeletePayment(payment)">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        else if (isPendingReview && isTransfer)
                                        {
                                            <span class="status-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;">
                                                <i class="fa-solid fa-clock"></i> En revision
                                            </span>
                                        }
                                        else if (isPending)
                                        {
                                            <div style="display:flex;gap:0.4rem;justify-content:center;">
                                                <button class="btn btn-sm btn-primary" title="Reintentar pago"
                                                        disabled="@(processingPlanId is not null)"
                                                        @onclick="() => RetryPayment(payment)">
                                                    <i class="fa-solid fa-rotate-right"></i> Pagar
                                                </button>
                                                <button class="btn btn-sm btn-danger" title="Eliminar"
                                                        disabled="@(deletingPaymentId == payment.Id)"
                                                        @onclick="() => ConfirmDeletePayment(payment)">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:var(--text-muted);">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (showCheckoutModal && checkoutPlan is not null)
    {
        var subTotal = checkoutPlan.Price;
        var ivaAmount = Math.Round(subTotal * 0.21m, 2);
        var totalConIva = Math.Round(subTotal * 1.21m, 2);
        var totalTransferencia = Math.Round(totalConIva * 0.95m, 2);

        <div class="modal-overlay" @onclick="() => showCheckoutModal = false">
            <div class="modal-card" @onclick:stopPropagation="true" style="max-width:460px;">
                <div class="modal-header">
                    <h3><i class="fa-solid fa-cart-shopping" style="margin-right:0.5rem;"></i>@checkoutPlan.Name</h3>
                    <button class="btn-close" @onclick="() => showCheckoutModal = false">&times;</button>
                </div>
                <div class="modal-body">
                    <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.25rem;">
                        <div style="display:flex;justify-content:space-between;font-size:0.9rem;color:var(--text-secondary);">
                            <span>Subtotal (@checkoutPlan.Classes @(checkoutPlan.Classes == 1 ? "clase" : "clases"))</span>
                            <span>$@FormatPrice(subTotal, false)</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:0.9rem;color:var(--text-secondary);">
                            <span>IVA (21%)</span>
                            <span>$@FormatPrice(ivaAmount, false)</span>
                        </div>
                        <div style="border-top:1px solid var(--border);padding-top:0.5rem;display:flex;justify-content:space-between;font-size:1.15rem;font-weight:700;">
                            <span>Total</span>
                            <span>$@FormatPrice(totalConIva, false)</span>
                        </div>
                    </div>

                    <div style="display:flex;flex-direction:column;gap:0.6rem;">
                        <button class="btn btn-primary" style="width:100%;justify-content:center;padding:0.7rem;"
                                disabled="@(processingPlanId == checkoutPlan.Id)"
                                @onclick="() => ComprarPlan(checkoutPlan)">
                            @if (processingPlanId == checkoutPlan.Id)
                            {
                                <span>Procesando...</span>
                            }
                            else
                            {
                                <span><i class="fa-solid fa-credit-card" style="margin-right:0.4rem;"></i>Pagar con MercadoPago</span>
                            }
                        </button>
                        <button class="btn btn-secondary" style="width:100%;justify-content:center;padding:0.7rem;"
                                disabled="@(processingPlanId == checkoutPlan.Id)"
                                @onclick="() => PagarTransferencia(checkoutPlan, totalTransferencia)">
                            <span><i class="fa-solid fa-building-columns" style="margin-right:0.4rem;"></i>Transferencia $@FormatPrice(totalTransferencia, false) <span style="color:var(--primary);font-weight:700;">(-5%)</span></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteConfirm && paymentToDelete is not null)
    {
        <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
            <div class="modal-card modal-small" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Eliminar pago pendiente</h3>
                </div>
                <div class="modal-body">
                    <p>¿Estas seguro que queres eliminar el pago pendiente de <strong>@paymentToDelete.PlanName</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">
                        <i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar
                    </button>
                    <button class="btn btn-danger" disabled="@(deletingPaymentId is not null)" @onclick="DeletePayment">
                        <i class="fa-solid fa-trash" style="margin-right:0.3rem;"></i>@(deletingPaymentId is not null ? "Eliminando..." : "Eliminar")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showTransferModal)
    {
        <div class="modal-overlay" @onclick="() => showTransferModal = false">
            <div class="modal-card" @onclick:stopPropagation="true" style="max-width:480px;">
                <div class="modal-header">
                    <h3><i class="fa-solid fa-building-columns" style="margin-right:0.5rem;"></i>Pago por Transferencia</h3>
                    <button class="btn-close" @onclick="() => showTransferModal = false">&times;</button>
                </div>
                <div class="modal-body">
                    <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:8px;padding:1rem;margin-bottom:1rem;">
                        <div style="font-size:0.8rem;color:var(--primary);font-weight:600;margin-bottom:0.25rem;">
                            <i class="fa-solid fa-tag"></i> 5% de descuento aplicado
                        </div>
                        <div style="font-size:1.5rem;font-weight:700;">$@FormatPrice(transferAmount, false)</div>
                        <div style="font-size:0.8rem;color:var(--text-secondary);">@transferPlanName - IVA incluido</div>
                    </div>

                    <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">
                        Realiza la transferencia con los datos que se indican abajo y luego subi el comprobante desde el historial de pagos.
                    </p>

                    <div style="display:flex;flex-direction:column;gap:0.75rem;">
                        @if (!string.IsNullOrEmpty(transferCvu))
                        {
                            <div style="background:var(--bg);border-radius:8px;padding:0.75rem 1rem;">
                                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);font-weight:600;">CVU</div>
                                <div style="font-family:monospace;font-size:0.95rem;font-weight:600;word-break:break-all;">@transferCvu</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(transferAlias))
                        {
                            <div style="background:var(--bg);border-radius:8px;padding:0.75rem 1rem;">
                                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);font-weight:600;">Alias</div>
                                <div style="font-size:0.95rem;font-weight:600;">@transferAlias</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(transferTitular))
                        {
                            <div style="background:var(--bg);border-radius:8px;padding:0.75rem 1rem;">
                                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);font-weight:600;">Titular</div>
                                <div style="font-size:0.95rem;font-weight:600;">@transferTitular</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="CloseTransferModal">
                        <i class="fa-solid fa-check" style="margin-right:0.3rem;"></i>Entendido
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<PaymentPlanDto> plans = new();
    private List<PaymentDto>? payments;
    private bool isLoading = true;
    private int? processingPlanId;
    private bool isPayPal;
    private string detectedProvider = "mercadopago";
    private bool showDeleteConfirm;
    private PaymentDto? paymentToDelete;
    private int? deletingPaymentId;
    private bool showCheckoutModal;
    private PaymentPlanDto? checkoutPlan;
    private bool showTransferModal;
    private string transferCvu = "";
    private string transferAlias = "";
    private string transferTitular = "";
    private decimal transferAmount;
    private string transferPlanName = "";

    [SupplyParameterFromQuery(Name = "U")]
    public string? CountryOverride { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Detect country (URL param ?U=MX overrides IP detection)
            var countryResult = await Api.DetectCountryAsync(CountryOverride);
            if (countryResult is not null)
            {
                detectedProvider = countryResult.Provider;
                isPayPal = detectedProvider == "paypal";
            }

            var plansResult = await Api.GetPaymentPlansAsync();
            if (plansResult is not null && plansResult.Count > 0)
            {
                plans = plansResult.Where(p => p.IsActive).OrderBy(p => p.Classes).ToList();
            }

            payments = await Api.GetMyPaymentsAsync();
        }
        catch
        {
            // Plans endpoint may not exist yet - show empty state
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCheckoutModal(PaymentPlanDto plan)
    {
        checkoutPlan = plan;
        showCheckoutModal = true;
    }

    private async Task ComprarPlan(PaymentPlanDto plan)
    {
        processingPlanId = plan.Id;
        showCheckoutModal = false;
        StateHasChanged();

        try
        {
            var result = await Api.CreatePaymentAsync(plan.Id, detectedProvider);
            if (result is not null && !string.IsNullOrEmpty(result.CheckoutUrl))
            {
                await JS.InvokeVoidAsync("eval", $"window.location.href = '{result.CheckoutUrl}'");
                return;
            }
            else
            {
                ToastService.Error("No se pudo crear el pago. Intenta de nuevo.");
            }
        }
        catch
        {
            ToastService.Error("Error al procesar el pago. Intenta de nuevo.");
        }
        finally
        {
            processingPlanId = null;
            StateHasChanged();
        }
    }

    private string FormatPrice(decimal price, bool usd = false)
    {
        if (usd)
            return price.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);
        return price.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    }

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "approved" or "aprobado" => "status-success",
        "pending" or "pendiente" => "status-warning",
        "pending_review" => "status-info",
        "rejected" or "rechazado" => "status-danger",
        _ => "status-muted"
    };

    private string GetStatusLabel(string status) => status?.ToLower() switch
    {
        "approved" or "aprobado" => "Aprobado",
        "pending" or "pendiente" => "Pendiente",
        "pending_review" => "En revision",
        "rejected" or "rechazado" => "Rechazado",
        _ => status ?? "—"
    };

    private async Task RetryPayment(PaymentDto payment)
    {
        var provider = payment.PaymentProvider ?? detectedProvider;
        processingPlanId = payment.PlanId;
        StateHasChanged();

        try
        {
            var result = await Api.CreatePaymentAsync(payment.PlanId, provider);
            if (result is not null && !string.IsNullOrEmpty(result.CheckoutUrl))
            {
                await JS.InvokeVoidAsync("eval", $"window.location.href = '{result.CheckoutUrl}'");
                return;
            }
            else
            {
                ToastService.Error("No se pudo crear el pago. Intenta de nuevo.");
            }
        }
        catch
        {
            ToastService.Error("Error al procesar el pago. Intenta de nuevo.");
        }
        finally
        {
            processingPlanId = null;
            StateHasChanged();
        }
    }

    private void ConfirmDeletePayment(PaymentDto payment)
    {
        paymentToDelete = payment;
        showDeleteConfirm = true;
    }

    private async Task DeletePayment()
    {
        if (paymentToDelete is null) return;

        deletingPaymentId = paymentToDelete.Id;
        StateHasChanged();

        try
        {
            var success = await Api.DeletePaymentAsync(paymentToDelete.Id);
            if (success)
            {
                payments?.RemoveAll(p => p.Id == paymentToDelete.Id);
                ToastService.Success("Pago pendiente eliminado");
            }
            else
            {
                ToastService.Error("No se pudo eliminar el pago");
            }
        }
        catch
        {
            ToastService.Error("Error al eliminar el pago");
        }
        finally
        {
            deletingPaymentId = null;
            showDeleteConfirm = false;
            paymentToDelete = null;
            StateHasChanged();
        }
    }

    private async Task PagarTransferencia(PaymentPlanDto plan, decimal amount)
    {
        processingPlanId = plan.Id;
        showCheckoutModal = false;
        StateHasChanged();

        try
        {
            var result = await Api.CreateTransferPaymentAsync(plan.Id);
            if (result is not null && result.Transfer)
            {
                transferCvu = result.Cvu;
                transferAlias = result.Alias;
                transferTitular = result.Titular;
                transferAmount = result.Amount;
                transferPlanName = plan.Name;
                showTransferModal = true;

                // Refresh payments list
                payments = await Api.GetMyPaymentsAsync();
            }
            else
            {
                ToastService.Error("No se pudo crear el pago por transferencia.");
            }
        }
        catch
        {
            ToastService.Error("Error al procesar el pago.");
        }
        finally
        {
            processingPlanId = null;
            StateHasChanged();
        }
    }

    private void CloseTransferModal()
    {
        showTransferModal = false;
    }

    private async Task UploadReceipt(InputFileChangeEventArgs e, PaymentDto payment)
    {
        var file = e.File;
        if (file is null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            ToastService.Error("El archivo no puede superar 5 MB");
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var success = await Api.UploadTransferReceiptAsync(payment.Id, stream, file.Name);
            if (success)
            {
                ToastService.Success("Comprobante subido. Tu pago sera revisado.");
                payments = await Api.GetMyPaymentsAsync();
                StateHasChanged();
            }
            else
            {
                ToastService.Error("No se pudo subir el comprobante");
            }
        }
        catch
        {
            ToastService.Error("Error al subir el comprobante");
        }
    }
}
