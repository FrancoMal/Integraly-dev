@page "/changelog"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@using System.Text.Json

<div class="card">
    <div class="card-header">
        <h3>Filtros</h3>
    </div>
    <div class="card-body">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">Desde</label>
                <input class="form-input" type="date" @bind="filterFrom" />
            </div>
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">Hasta</label>
                <input class="form-input" type="date" @bind="filterTo" />
            </div>
            <div class="form-group" style="margin-bottom: 0; flex: 1; min-width: 200px;">
                <label class="form-label">Buscar</label>
                <input class="form-input" type="text" placeholder="Buscar en cambios..." @bind="filterSearch" @onkeydown="HandleSearchKeyDown" />
            </div>
            <button class="btn btn-primary" @onclick="Search" style="height: fit-content;">
                <i class="fa-solid fa-magnifying-glass" style="margin-right:0.3rem;"></i>Buscar
            </button>
        </div>
    </div>
</div>

@if (selectedDate.HasValue && detail is not null)
{
    <!-- DETAIL VIEW -->
    <div style="margin-top: 1.5rem;">
        <button class="btn btn-secondary" @onclick="BackToList" style="margin-bottom: 1rem;">
            <i class="fa-solid fa-arrow-left" style="margin-right:0.3rem;"></i>Volver
        </button>

        <div class="card">
            <div class="card-header">
                <h3>@detail.Date.ToString("dddd d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))</h3>
            </div>
            <div class="card-body">
                <p style="color: var(--text-secondary); margin-bottom: 1rem;">@detail.GeneralSummary</p>
                <div style="display:flex; gap:0.5rem; margin-bottom:1.5rem;">
                    <span class="status-badge status-active">@detail.TotalCommits commits</span>
                    <span class="status-badge" style="background:#e0e7ff;color:#3730a3;">@detail.TotalGroups grupos</span>
                </div>

                @foreach (var group in detail.Groups)
                {
                    <div class="changelog-group @(IsGroupExpanded(group.Id) ? "expanded" : "")">
                        <div class="changelog-group-header" @onclick="() => ToggleGroup(group.Id)">
                            <div style="flex:1;">
                                <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                                    <strong>@group.GroupTitle</strong>
                                    @foreach (var tag in group.Tags)
                                    {
                                        <span class="changelog-tag changelog-tag-@tag.ToLower()">@tag</span>
                                    }
                                </div>
                                <p style="color:var(--text-secondary); margin:0.25rem 0 0 0; font-size:0.9rem;">@group.GroupSummary</p>
                            </div>
                            <div style="display:flex; align-items:center; gap:0.75rem;">
                                <div class="changelog-author" @onclick:stopPropagation="true">
                                    @if (editingAuthorGroupId == group.Id)
                                    {
                                        <input class="form-input" type="text" @bind="editingAuthorValue"
                                               placeholder="Nombre del autor" style="width:150px; font-size:0.85rem; padding:0.25rem 0.5rem;"
                                               @onkeydown="(e) => HandleAuthorKeyDown(e, group.Id)" />
                                        <button class="btn btn-primary" style="padding:0.2rem 0.5rem; font-size:0.8rem;" @onclick="() => SaveAuthor(group.Id)">OK</button>
                                        <button class="btn btn-secondary" style="padding:0.2rem 0.5rem; font-size:0.8rem;" @onclick="CancelEditAuthor">X</button>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.85rem; color:@(string.IsNullOrEmpty(group.Author) ? "var(--text-muted)" : "var(--text-primary)")">
                                            @(string.IsNullOrEmpty(group.Author) ? "Sin autor" : group.Author)
                                        </span>
                                        <button class="changelog-edit-btn" @onclick="() => StartEditAuthor(group.Id, group.Author)" title="Editar autor">
                                            <i class="fa-solid fa-pencil"></i>
                                        </button>
                                    }
                                </div>
                                <span class="changelog-chevron">
                                    <i class="fa-solid @(IsGroupExpanded(group.Id) ? "fa-chevron-up" : "fa-chevron-down")"></i>
                                </span>
                            </div>
                        </div>

                        @if (IsGroupExpanded(group.Id))
                        {
                            <div class="changelog-group-body">
                                @foreach (var commit in ParseCommits(group.CommitsJson))
                                {
                                    <div class="changelog-commit">
                                        <code class="changelog-hash">@(commit.Hash.Length > 7 ? commit.Hash[..7] : commit.Hash)</code>
                                        <span class="changelog-message">@commit.Message</span>
                                        <span class="changelog-time">@commit.Timestamp</span>
                                    </div>
                                    @if (commit.FilesChanged.Any())
                                    {
                                        <div class="changelog-files">
                                            @foreach (var file in commit.FilesChanged)
                                            {
                                                <span class="changelog-file">@file</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <!-- LIST VIEW -->
    <div class="card" style="margin-top: 1.5rem;">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
            <h3>Historial de Cambios (@total)</h3>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <p class="text-muted">Cargando...</p>
            }
            else if (items is null || !items.Any())
            {
                <p class="text-muted">No hay cambios registrados para los filtros seleccionados</p>
            }
            else
            {
                @foreach (var day in items)
                {
                    <div class="changelog-day-card" @onclick="() => LoadDetail(day.Date)">
                        <div class="changelog-day-header">
                            <div>
                                <h4 style="margin:0;">@day.Date.ToString("dddd d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))</h4>
                                <p style="color:var(--text-secondary); margin:0.25rem 0 0 0; font-size:0.9rem;">@day.GeneralSummary</p>
                            </div>
                            <div style="display:flex; gap:0.5rem; align-items:center;">
                                <span class="status-badge status-active">@day.TotalCommits commits</span>
                                <span class="status-badge" style="background:#e0e7ff;color:#3730a3;">@day.TotalGroups grupos</span>
                                <i class="fa-solid fa-chevron-right" style="color:var(--text-muted);"></i>
                            </div>
                        </div>
                    </div>
                }

                @if (totalPages > 1)
                {
                    <div style="display:flex; justify-content:center; gap:0.5rem; margin-top:1rem; align-items:center;">
                        <button class="btn btn-secondary" disabled="@(currentPage <= 1)" @onclick="PrevPage">Anterior</button>
                        <span style="color:var(--text-secondary);">Pagina @currentPage de @totalPages</span>
                        <button class="btn btn-secondary" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Siguiente</button>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private DateTime? filterFrom;
    private DateTime? filterTo;
    private string? filterSearch;
    private bool isLoading = true;
    private List<DailyChangeSummaryListDto>? items;
    private int total;
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages => (int)Math.Ceiling((double)total / pageSize);

    // Detail view
    private DateTime? selectedDate;
    private DailyChangeSummaryDetailDto? detail;
    private HashSet<int> expandedGroups = new();

    // Author editing
    private int? editingAuthorGroupId;
    private string? editingAuthorValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            isLoading = true;
            StateHasChanged();
            var result = await Api.GetChangelogAsync(filterFrom, filterTo, filterSearch, currentPage);
            if (result is not null)
            {
                items = result.Items;
                total = result.Total;
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el historial: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Search()
    {
        currentPage = 1;
        await LoadList();
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadList();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadList();
        }
    }

    private async Task LoadDetail(DateTime date)
    {
        try
        {
            detail = await Api.GetChangelogDetailAsync(date);
            selectedDate = date;
            expandedGroups.Clear();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el detalle: " + ex.Message);
        }
    }

    private void BackToList()
    {
        selectedDate = null;
        detail = null;
    }

    private void ToggleGroup(int groupId)
    {
        if (!expandedGroups.Remove(groupId))
            expandedGroups.Add(groupId);
    }

    private bool IsGroupExpanded(int groupId) => expandedGroups.Contains(groupId);

    private void StartEditAuthor(int groupId, string? currentAuthor)
    {
        editingAuthorGroupId = groupId;
        editingAuthorValue = currentAuthor;
    }

    private void CancelEditAuthor()
    {
        editingAuthorGroupId = null;
        editingAuthorValue = null;
    }

    private async Task HandleAuthorKeyDown(KeyboardEventArgs e, int groupId)
    {
        if (e.Key == "Enter") await SaveAuthor(groupId);
        if (e.Key == "Escape") CancelEditAuthor();
    }

    private async Task SaveAuthor(int groupId)
    {
        try
        {
            var success = await Api.UpdateCommitGroupAuthorAsync(groupId, editingAuthorValue);
            if (success)
            {
                var group = detail?.Groups.FirstOrDefault(g => g.Id == groupId);
                if (group is not null) group.Author = editingAuthorValue;
                ToastService.Success("Autor actualizado");
            }
            else
            {
                ToastService.Error("No se pudo actualizar el autor");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
        finally
        {
            CancelEditAuthor();
        }
    }

    private List<CommitDetail> ParseCommits(string json)
    {
        try
        {
            return JsonSerializer.Deserialize<List<CommitDetail>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch
        {
            return new();
        }
    }
}
