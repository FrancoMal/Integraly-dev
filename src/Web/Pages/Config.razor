@page "/config"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="view-header">
    <h2>Configuracion</h2>
    <p class="view-subtitle">Ajustes generales de la plataforma</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Ajustes</h3>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(message))
            {
                <div class="@(messageSuccess ? "form-success" : "form-error")">@message</div>
            }

            <div class="form-group">
                <label class="form-label">Nombre de la marca</label>
                <input class="form-input" @bind="brandName" placeholder="Integraly" />
                <small class="text-muted">Se muestra en el sidebar y la barra superior</small>
            </div>

            <div class="form-group">
                <label class="form-label">Horas minimas para cancelar una reserva</label>
                <input class="form-input" type="number" @bind="cancellationHours" min="0" max="72" />
                <small class="text-muted">Cuantas horas antes de la clase se puede cancelar (0 = cancelacion libre)</small>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveSettings" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar Configuracion")
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isSaving;
    private string? message;
    private bool messageSuccess;

    private string brandName = "Integraly";
    private int cancellationHours = 24;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                if (settings.TryGetValue("BrandName", out var bn))
                    brandName = bn;
                if (settings.TryGetValue("CancellationHours", out var ch) && int.TryParse(ch, out var hours))
                    cancellationHours = hours;
            }
        }
        catch
        {
            ToastService.Error("Error al cargar la configuracion");
        }
        isLoading = false;
    }

    private async Task SaveSettings()
    {
        message = null;
        isSaving = true;

        try
        {
            var r1 = await Api.UpdateSettingAsync("BrandName", brandName);
            var r2 = await Api.UpdateSettingAsync("CancellationHours", cancellationHours.ToString());

            if (r1 && r2)
            {
                message = "Configuracion guardada correctamente";
                messageSuccess = true;
                ToastService.Success("Configuracion guardada");
            }
            else
            {
                message = "Error al guardar algunos ajustes";
                messageSuccess = false;
            }
        }
        catch
        {
            message = "Error al guardar la configuracion";
            messageSuccess = false;
        }

        isSaving = false;
    }
}
