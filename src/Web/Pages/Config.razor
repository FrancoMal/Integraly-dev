@page "/config"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header">
        <h3>Ajustes Generales</h3>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(message))
            {
                <div class="@(messageSuccess ? "form-success" : "form-error")">@message</div>
            }

            <div class="form-group">
                <label class="form-label">Nombre de la marca</label>
                <input class="form-input" @bind="brandName" placeholder="Integraly" />
                <small class="text-muted">Se muestra en el sidebar y la barra superior</small>
            </div>

            <div class="form-group">
                <label class="form-label">Zona horaria por defecto</label>
                <select class="form-input" @bind="defaultTimezone">
                    @foreach (var tz in TimezoneService.GetTimezones())
                    {
                        <option value="@tz.Id">@tz.Label</option>
                    }
                </select>
                <small class="text-muted">Zona horaria para usuarios nuevos. Cada usuario puede cambiarla en su perfil.</small>
            </div>

            <h4 style="margin-top: 1.5rem; margin-bottom: 0.75rem;">Indicador de disponibilidad</h4>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Verde desde (instructores disponibles)</label>
                    <input class="form-input" type="number" @bind="greenMin" min="1" max="20" />
                    <small class="text-muted">Si hay esta cantidad o mas, el icono es verde</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Amarillo desde</label>
                    <input class="form-input" type="number" @bind="yellowMin" min="1" max="20" />
                    <small class="text-muted">Si hay esta cantidad o mas (pero menos que verde), es amarillo. Menos es rojo.</small>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Horas minimas para cancelar una reserva</label>
                <input class="form-input" type="number" @bind="cancellationHours" min="0" max="72" />
                <small class="text-muted">Cuantas horas antes de la clase se puede cancelar (0 = cancelacion libre)</small>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveSettings" disabled="@isSaving">
                    <i class="fa-solid fa-floppy-disk" style="margin-right:0.3rem;"></i>@(isSaving ? "Guardando..." : "Guardar Configuracion")
                </button>
            </div>
        }
    </div>
</div>

<div class="card" style="margin-top: 1.5rem;">
    <div class="card-header">
        <h3>Configuracion SMTP (Email)</h3>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(smtpMessage))
            {
                <div class="@(smtpMessageSuccess ? "form-success" : "form-error")">@smtpMessage</div>
            }

            <div class="form-group">
                <label class="form-label">Servidor SMTP</label>
                <input class="form-input" @bind="smtpHost" placeholder="mail.ejemplo.com" />
            </div>

            <div class="form-group">
                <label class="form-label">Puerto SMTP</label>
                <input class="form-input" type="number" @bind="smtpPort" min="1" max="65535" />
            </div>

            <div class="form-group">
                <label class="form-label">Nombre del remitente</label>
                <input class="form-input" @bind="smtpSenderName" placeholder="Integraly" />
            </div>

            <div class="form-group">
                <label class="form-label">Email del remitente</label>
                <input class="form-input" type="email" @bind="smtpSenderEmail" placeholder="ventas@ejemplo.com" />
            </div>

            <div class="form-group">
                <label class="form-label">Usuario SMTP</label>
                <input class="form-input" @bind="smtpUser" placeholder="ventas@ejemplo.com" />
            </div>

            <div class="form-group">
                <label class="form-label">Contrasena SMTP</label>
                <input class="form-input" type="password" @bind="smtpPassword" />
            </div>

            <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="smtpSsl" @bind="smtpUseSsl" />
                <label for="smtpSsl" class="form-label" style="margin: 0;">Usar SSL</label>
            </div>

            <div class="form-actions" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                <button class="btn btn-primary" @onclick="SaveSmtpSettings" disabled="@isSmtpSaving">
                    <i class="fa-solid fa-floppy-disk" style="margin-right:0.3rem;"></i>@(isSmtpSaving ? "Guardando..." : "Guardar SMTP")
                </button>
            </div>

            <hr style="margin: 1.5rem 0; border-color: rgba(255,255,255,0.1);" />

            <h4 style="margin-bottom: 1rem;">Enviar email de prueba</h4>
            <div class="form-group" style="display: flex; gap: 0.75rem; align-items: flex-end; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label class="form-label">Email de destino</label>
                    <input class="form-input" type="email" @bind="testEmailTo" placeholder="test@ejemplo.com" />
                </div>
                <button class="btn btn-secondary" @onclick="SendTestEmail" disabled="@isSendingTest" style="height: fit-content;">
                    <i class="fa-solid fa-paper-plane" style="margin-right:0.3rem;"></i>@(isSendingTest ? "Enviando..." : "Enviar prueba")
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isSaving;
    private string? message;
    private bool messageSuccess;

    private string brandName = "Integraly";
    private string defaultTimezone = "America/Argentina/Buenos_Aires";
    private int greenMin = 3;
    private int yellowMin = 2;
    private int cancellationHours = 24;

    // SMTP fields
    private string smtpHost = "";
    private int smtpPort = 587;
    private string smtpSenderName = "Integraly";
    private string smtpSenderEmail = "";
    private string smtpUser = "";
    private string smtpPassword = "";
    private bool smtpUseSsl;
    private bool isSmtpSaving;
    private string? smtpMessage;
    private bool smtpMessageSuccess;

    // Test email
    private string testEmailTo = "";
    private bool isSendingTest;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                if (settings.TryGetValue("BrandName", out var bn))
                    brandName = bn;
                if (settings.TryGetValue("DefaultTimezone", out var dtz))
                    defaultTimezone = dtz;
                if (settings.TryGetValue("AvailabilityGreenMin", out var gm) && int.TryParse(gm, out var gv))
                    greenMin = gv;
                if (settings.TryGetValue("AvailabilityYellowMin", out var ym) && int.TryParse(ym, out var yv))
                    yellowMin = yv;
                if (settings.TryGetValue("CancellationHours", out var ch) && int.TryParse(ch, out var hours))
                    cancellationHours = hours;

                // SMTP
                if (settings.TryGetValue("SmtpHost", out var sh))
                    smtpHost = sh;
                if (settings.TryGetValue("SmtpPort", out var sp) && int.TryParse(sp, out var port))
                    smtpPort = port;
                if (settings.TryGetValue("SmtpSenderName", out var sn))
                    smtpSenderName = sn;
                if (settings.TryGetValue("SmtpSenderEmail", out var se))
                    smtpSenderEmail = se;
                if (settings.TryGetValue("SmtpUser", out var su))
                    smtpUser = su;
                if (settings.TryGetValue("SmtpPassword", out var spw))
                    smtpPassword = spw;
                if (settings.TryGetValue("SmtpUseSsl", out var ssl))
                    smtpUseSsl = ssl == "true";
            }
        }
        catch
        {
            ToastService.Error("Error al cargar la configuracion");
        }
        isLoading = false;
    }

    private async Task SaveSettings()
    {
        message = null;
        isSaving = true;

        try
        {
            var r1 = await Api.UpdateSettingAsync("BrandName", brandName);
            var r2 = await Api.UpdateSettingAsync("DefaultTimezone", defaultTimezone);
            var r3 = await Api.UpdateSettingAsync("AvailabilityGreenMin", greenMin.ToString());
            var r4 = await Api.UpdateSettingAsync("AvailabilityYellowMin", yellowMin.ToString());
            var r5 = await Api.UpdateSettingAsync("CancellationHours", cancellationHours.ToString());

            if (r1 && r2 && r3 && r4 && r5)
            {
                message = "Configuracion guardada correctamente";
                messageSuccess = true;
                ToastService.Success("Configuracion guardada");
            }
            else
            {
                message = "Error al guardar algunos ajustes";
                messageSuccess = false;
            }
        }
        catch
        {
            message = "Error al guardar la configuracion";
            messageSuccess = false;
        }

        isSaving = false;
    }

    private async Task SaveSmtpSettings()
    {
        smtpMessage = null;
        isSmtpSaving = true;

        try
        {
            var results = new List<bool>();
            results.Add(await Api.UpdateSettingAsync("SmtpHost", smtpHost));
            results.Add(await Api.UpdateSettingAsync("SmtpPort", smtpPort.ToString()));
            results.Add(await Api.UpdateSettingAsync("SmtpSenderName", smtpSenderName));
            results.Add(await Api.UpdateSettingAsync("SmtpSenderEmail", smtpSenderEmail));
            results.Add(await Api.UpdateSettingAsync("SmtpUser", smtpUser));
            results.Add(await Api.UpdateSettingAsync("SmtpPassword", smtpPassword));
            results.Add(await Api.UpdateSettingAsync("SmtpUseSsl", smtpUseSsl ? "true" : "false"));

            if (results.All(r => r))
            {
                smtpMessage = "Configuracion SMTP guardada correctamente";
                smtpMessageSuccess = true;
                ToastService.Success("SMTP guardado");
            }
            else
            {
                smtpMessage = "Error al guardar algunos ajustes SMTP";
                smtpMessageSuccess = false;
            }
        }
        catch
        {
            smtpMessage = "Error al guardar la configuracion SMTP";
            smtpMessageSuccess = false;
        }

        isSmtpSaving = false;
    }

    private async Task SendTestEmail()
    {
        if (string.IsNullOrWhiteSpace(testEmailTo))
        {
            ToastService.Error("Ingresa un email de destino");
            return;
        }

        isSendingTest = true;
        try
        {
            var result = await Api.SendTestEmailAsync(testEmailTo);
            if (result)
            {
                ToastService.Success("Email de prueba enviado correctamente");
            }
            else
            {
                ToastService.Error("Error al enviar el email. Verifica la configuracion SMTP.");
            }
        }
        catch
        {
            ToastService.Error("Error al enviar el email de prueba");
        }
        isSendingTest = false;
    }
}
