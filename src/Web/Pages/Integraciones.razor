    // ===== Email =====
    private void OpenEmailModal()
    {
        var i = integrations.FirstOrDefault(x => x.Provider == "email-smtp");
        emailHasSecret = i?.HasSecret ?? false;
        emailIsActive = i?.IsActive ?? false;
        emailPassword = "";

        if (!string.IsNullOrEmpty(i?.Settings))
        {
            try
            {
                var s = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(i.Settings);
                emailSmtpHost = s?.GetValueOrDefault("smtpHost")?.ToString() ?? "smtp.gmail.com";
                emailSmtpPort = int.TryParse(s?.GetValueOrDefault("smtpPort")?.ToString(), out var p) ? p : 587;
                emailSmtpTls = s?.GetValueOrDefault("smtpTls")?.ToString() == "True" || s?.GetValueOrDefault("smtpTls")?.ToString() == "true";
                emailImapHost = s?.GetValueOrDefault("imapHost")?.ToString() ?? "imap.gmail.com";
                emailImapPort = int.TryParse(s?.GetValueOrDefault("imapPort")?.ToString(), out var p2) ? p2 : 993;
                emailImapTls = s?.GetValueOrDefault("imapTls")?.ToString() == "True" || s?.GetValueOrDefault("imapTls")?.ToString() == "true";
                emailFromName = s?.GetValueOrDefault("fromName")?.ToString() ?? "";
                emailFromAddress = s?.GetValueOrDefault("fromAddress")?.ToString() ?? "";
                emailUsername = s?.GetValueOrDefault("username")?.ToString() ?? "";
            }
            catch { }
        }

        showEmailModal = true;
    }

    private void CloseEmailModal() => showEmailModal = false;

    private async Task SaveEmailIntegration()
    {
        isSaving = true;
        try
        {
            var settings = System.Text.Json.JsonSerializer.Serialize(new
            {
                smtpHost = emailSmtpHost,
                smtpPort = emailSmtpPort,
                smtpTls = emailSmtpTls,
                imapHost = emailImapHost,
                imapPort = emailImapPort,
                imapTls = emailImapTls,
                fromName = emailFromName,
                fromAddress = emailFromAddress,
                username = emailUsername
            });

            await Api.SaveIntegrationAsync(new SaveIntegrationRequest
            {
                Provider = "email-smtp",
                AppId = emailFromAddress,
                AppSecret = string.IsNullOrEmpty(emailPassword) ? null : emailPassword,
                Settings = settings,
                IsActive = emailIsActive
            });
            ToastService.Success("Email guardado");
            showEmailModal = false;
            await LoadData();
        }
        catch { ToastService.Error("Error al guardar"); }
        isSaving = false;
    }

