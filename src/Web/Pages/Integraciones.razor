    // ===== WhatsApp =====
    private async Task StartWhatsAppLink()
    {
        var started = await Api.StartWhatsAppLinkAsync();
        if (!started) { ToastService.Error("Error al iniciar vinculacion"); return; }

        qrTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        showWaQrModal = true;
        StateHasChanged();

        // Poll every 3 seconds
        waTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                qrTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                var check = await Api.CheckWhatsAppLinkedAsync();
                if (check?.Linked == true)
                {
                    showWaQrModal = false;
                    waTimer?.Dispose();
                    waTimer = null;
                    await LoadData();
                    ToastService.Success("WhatsApp vinculado correctamente");
                }
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }, null, 3000, 3000);
    }

    private async Task CancelWhatsAppLink()
    {
        waTimer?.Dispose();
        waTimer = null;
        showWaQrModal = false;
        await Api.CancelWhatsAppLinkAsync();
    }

    private async Task UnlinkWhatsApp()
    {
        await Api.UnlinkWhatsAppAsync();
        ToastService.Success("WhatsApp desvinculado");
        await LoadData();
    }

    public void Dispose()
    {
        waTimer?.Dispose();
    }
