@page "/reservar"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="view-header">
    <h2>Reservar Clase</h2>
    <p class="view-subtitle">Explora los horarios disponibles de todos los instructores y reserva tu clase</p>
</div>

@if (remainingTokens.HasValue)
{
    <div class="stat-card" style="margin-bottom: 1.5rem; display: inline-flex;">
        <div class="stat-card-icon primary">@SvgIcons.Package</div>
        <div class="stat-card-info">
            <span class="stat-card-value">@remainingTokens</span>
            <span class="stat-card-label">Clases disponibles</span>
        </div>
    </div>
}

<div class="card" style="margin-bottom: 1rem;">
    <div class="card-body">
        <div class="week-navigator">
            <button class="btn btn-secondary btn-sm" @onclick="PreviousWeek">&lt; Anterior</button>
            <span class="week-label">@weekStart.ToString("dd/M") - @weekEnd.ToString("dd/M/yyyy")</span>
            <button class="btn btn-secondary btn-sm" @onclick="NextWeek">Siguiente &gt;</button>
        </div>
    </div>
</div>

@if (instructors is not null && instructors.Count > 0)
{
    <div class="card" style="margin-bottom: 1rem;">
        <div class="card-body" style="padding: 0.75rem 1rem;">
            <div class="instructor-filters">
                <span style="font-size: 0.8rem; font-weight: 600; margin-right: 0.5rem;">Filtrar instructores:</span>
                @foreach (var inst in instructors)
                {
                    var id = inst.Id;
                    var isChecked = selectedInstructorIds.Contains(id);
                    var color = GetInstructorColor(id);
                    <label class="instructor-chip @(isChecked ? "active" : "")" style="@(isChecked ? $"background: {color}22; border-color: {color}; color: {color};" : "")">
                        <input type="checkbox" checked="@isChecked" @onchange="() => ToggleInstructor(id)" style="display:none;" />
                        <span class="instructor-dot" style="background: @color;"></span>
                        @($"{inst.FirstName} {inst.LastName}".Trim())
                    </label>
                }
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body" style="padding: 0.5rem;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1rem;">Cargando...</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table calendar-compact reservar-grid">
                    <thead>
                        <tr>
                            <th style="width: 50px;">Hora</th>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = weekStart.AddDays(i);
                                <th style="text-align: center; width: 80px;">
                                    <div style="font-size: 0.75rem;">@dayNames[i]</div>
                                    <div style="font-size: 0.7rem; font-weight: 400; color: var(--text-muted);">@date.ToString("dd/M")</div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int hour = 8; hour <= 21; hour++)
                        {
                            var h = hour;
                            <tr>
                                <td style="font-size: 0.75rem; font-weight: 600; padding: 4px;">@($"{h:00}:00")</td>
                                @for (int i = 0; i < 7; i++)
                                {
                                    var date = weekStart.AddDays(i);
                                    var dayKey = $"{date:yyyy-MM-dd}-{h}";
                                    var available = GetAvailableInstructors(date, h);
                                    var isPast = date.Date < DateTime.Today || (date.Date == DateTime.Today && h <= DateTime.Now.Hour);
                                    <td style="text-align: center; padding: 4px; cursor: @(available.Count > 0 && !isPast ? "pointer" : "default");"
                                        class="@(isPast ? "calendar-past" : available.Count > 0 ? "calendar-slot-available" : "")"
                                        @onclick="() => OnSlotClick(date, h)">
                                        @if (!isPast && available.Count > 0)
                                        {
                                            <div class="slot-badges">
                                                @foreach (var inst in available)
                                                {
                                                    var color = GetInstructorColor(inst.Id);
                                                    <span class="slot-dot" style="background: @color;" title="@($"{inst.FirstName} {inst.LastName}".Trim())"></span>
                                                }
                                            </div>
                                            <span class="slot-count">@available.Count</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.8rem; flex-wrap: wrap; padding: 0 0.5rem;">
                @if (instructors is not null)
                {
                    @foreach (var inst in instructors.Where(i => selectedInstructorIds.Contains(i.Id)))
                    {
                        var color = GetInstructorColor(inst.Id);
                        <span style="display: inline-flex; align-items: center; gap: 4px;">
                            <span class="slot-dot" style="background: @color;"></span>
                            @($"{inst.FirstName} {inst.LastName}".Trim())
                        </span>
                    }
                }
            </div>
        }
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="() => showModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Reservar clase</h3>
            </div>
            <div class="modal-body">
                <p style="margin-bottom: 0.75rem;">
                    <strong>@modalDate.ToString("dddd dd/MM/yyyy")</strong> a las <strong>@($"{modalHour:00}:00 - {modalHour + 1:00}:00")</strong>
                </p>
                <p style="font-size: 0.85rem; margin-bottom: 0.75rem;">Selecciona un instructor:</p>
                <div class="modal-instructor-list">
                    @foreach (var inst in modalInstructors)
                    {
                        var id = inst.Id;
                        var color = GetInstructorColor(id);
                        var name = $"{inst.FirstName} {inst.LastName}".Trim();
                        <button class="modal-instructor-btn @(modalSelectedInstructorId == id ? "selected" : "")"
                                style="border-left: 3px solid @color;"
                                @onclick="() => { modalSelectedInstructorId = id; modalSelectedInstructorName = name; }">
                            @name (@inst.Username)
                        </button>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showModal = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="DoBooking" disabled="@(isBooking || modalSelectedInstructorId == 0)">
                    @(isBooking ? "Reservando..." : "Confirmar Reserva")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isBooking;
    private int? remainingTokens;

    private List<UserManageDto>? instructors;
    private HashSet<int> selectedInstructorIds = new();
    private Dictionary<int, List<AvailabilityDto>> instructorAvailability = new();
    private List<BookingDto>? weekBookings;

    private DateTime weekStart;
    private DateTime weekEnd;
    private string[] dayNames = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };

    // Modal state
    private bool showModal;
    private DateTime modalDate;
    private int modalHour;
    private List<UserManageDto> modalInstructors = new();
    private int modalSelectedInstructorId;
    private string modalSelectedInstructorName = "";

    // Colors for instructors
    private string[] instructorColors = { "#10b981", "#3b82f6", "#f59e0b", "#ef4444", "#8b5cf6", "#ec4899", "#14b8a6", "#f97316" };

    protected override async Task OnInitializedAsync()
    {
        // Start on current week (Monday)
        var today = DateTime.Today;
        var dayOfWeek = (int)today.DayOfWeek;
        var daysToMonday = dayOfWeek == 0 ? 6 : dayOfWeek - 1;
        weekStart = today.AddDays(-daysToMonday);
        weekEnd = weekStart.AddDays(6);

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var usersTask = Api.GetUsersAsync();
            var dashTask = Api.GetUserDashboardAsync();
            await Task.WhenAll(usersTask, dashTask);

            var allUsers = usersTask.Result;
            instructors = allUsers?.Where(u => u.Role?.ToLower() == "instructor" && u.IsActive).ToList() ?? new();

            var dash = dashTask.Result;
            if (dash is not null)
                remainingTokens = dash.RemainingTokens;

            // Select all instructors by default
            selectedInstructorIds = new HashSet<int>(instructors.Select(i => i.Id));

            // Load availability for each instructor in parallel
            var availTasks = instructors.Select(async inst =>
            {
                var avail = await Api.GetInstructorAvailabilityAsync(inst.Id);
                return (inst.Id, Availability: avail ?? new List<AvailabilityDto>());
            }).ToList();

            var results = await Task.WhenAll(availTasks);
            instructorAvailability = results.ToDictionary(r => r.Id, r => r.Availability);

            // Load week bookings
            await LoadWeekBookings();
        }
        catch
        {
            ToastService.Error("Error al cargar los datos");
        }

        isLoading = false;
    }

    private async Task LoadWeekBookings()
    {
        try
        {
            weekBookings = await Api.GetWeekBookingsAsync(weekStart, weekEnd);
        }
        catch
        {
            weekBookings = new();
        }
    }

    private string GetInstructorColor(int instructorId)
    {
        if (instructors is null) return instructorColors[0];
        var index = instructors.FindIndex(i => i.Id == instructorId);
        return index >= 0 ? instructorColors[index % instructorColors.Length] : instructorColors[0];
    }

    private List<UserManageDto> GetAvailableInstructors(DateTime date, int hour)
    {
        if (instructors is null) return new();

        var dayOfWeek = (int)date.DayOfWeek;
        var result = new List<UserManageDto>();

        foreach (var inst in instructors)
        {
            if (!selectedInstructorIds.Contains(inst.Id)) continue;

            // Check if instructor has availability for this DayOfWeek + Hour
            if (!instructorAvailability.TryGetValue(inst.Id, out var avail)) continue;
            var hasSlot = avail.Any(a => a.DayOfWeek == dayOfWeek && a.StartHour == hour && a.IsActive);
            if (!hasSlot) continue;

            // Check if there's already a booking for this instructor at this date+hour
            var isBooked = weekBookings?.Any(b =>
                b.InstructorId == inst.Id &&
                b.ScheduledDate.Date == date.Date &&
                b.StartHour == hour) ?? false;
            if (isBooked) continue;

            result.Add(inst);
        }

        return result;
    }

    private void ToggleInstructor(int id)
    {
        if (selectedInstructorIds.Contains(id))
            selectedInstructorIds.Remove(id);
        else
            selectedInstructorIds.Add(id);
    }

    private async Task PreviousWeek()
    {
        weekStart = weekStart.AddDays(-7);
        weekEnd = weekEnd.AddDays(-7);
        await LoadWeekBookings();
    }

    private async Task NextWeek()
    {
        weekStart = weekStart.AddDays(7);
        weekEnd = weekEnd.AddDays(7);
        await LoadWeekBookings();
    }

    private void OnSlotClick(DateTime date, int hour)
    {
        var isPast = date.Date < DateTime.Today || (date.Date == DateTime.Today && hour <= DateTime.Now.Hour);
        if (isPast) return;

        var available = GetAvailableInstructors(date, hour);
        if (available.Count == 0) return;

        modalDate = date;
        modalHour = hour;
        modalInstructors = available;
        modalSelectedInstructorId = available.Count == 1 ? available[0].Id : 0;
        modalSelectedInstructorName = available.Count == 1 ? $"{available[0].FirstName} {available[0].LastName}".Trim() : "";
        showModal = true;
    }

    private async Task DoBooking()
    {
        if (modalSelectedInstructorId == 0) return;
        if (remainingTokens.HasValue && remainingTokens <= 0)
        {
            ToastService.Error("No tenes clases disponibles. Pedile al administrador que te cargue un pack.");
            return;
        }

        isBooking = true;
        try
        {
            var request = new CreateBookingRequest
            {
                InstructorId = modalSelectedInstructorId,
                ScheduledDate = modalDate,
                StartHour = modalHour
            };

            var result = await Api.CreateBookingAsync(request);
            if (result is not null)
            {
                ToastService.Success($"Clase reservada con {modalSelectedInstructorName}");
                showModal = false;
                if (remainingTokens.HasValue) remainingTokens--;
                await LoadWeekBookings();
            }
            else
            {
                ToastService.Error("Error al reservar la clase");
            }
        }
        catch
        {
            ToastService.Error("Error al reservar la clase");
        }
        isBooking = false;
    }
}
