@page "/reservar"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject TimezoneService TzService

@if (remainingTokens.HasValue)
{
    <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
        <div class="stat-card" style="display: inline-flex;">
            <div class="stat-card-icon primary">@SvgIcons.Package</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@remainingTokens</span>
                <span class="stat-card-label">Clases disponibles</span>
            </div>
        </div>
        <div class="stat-card" style="display: inline-flex;">
            <div class="stat-card-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">@SvgIcons.Calendar</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@bookedClasses</span>
                <span class="stat-card-label">Clases reservadas</span>
            </div>
        </div>
        <div class="stat-card" style="display: inline-flex;">
            <div class="stat-card-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">@SvgIcons.CheckCircle</div>
            <div class="stat-card-info">
                <span class="stat-card-value">@usedClasses</span>
                <span class="stat-card-label">Clases realizadas</span>
            </div>
        </div>
    </div>
}

<div class="card" style="margin-bottom: 1rem;">
    <div class="card-body" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem;">
        <div style="display:flex;gap:0.25rem;background:var(--bg-secondary,#f1f5f9);border-radius:6px;padding:2px;">
            <button class="btn btn-sm @(currentView == "calendario" ? "btn-primary" : "btn-ghost")" style="padding:0.25rem 0.6rem;font-size:0.75rem;" @onclick='() => currentView = "calendario"'>
                <i class="fa-solid fa-calendar-week" style="margin-right:0.3rem;"></i>Calendario
            </button>
            <button class="btn btn-sm @(currentView == "lista" ? "btn-primary" : "btn-ghost")" style="padding:0.25rem 0.6rem;font-size:0.75rem;" @onclick='() => currentView = "lista"'>
                <i class="fa-solid fa-list" style="margin-right:0.3rem;"></i>Lista
            </button>
        </div>
        @if (currentView == "calendario")
        {
            @if (instructors is not null && instructors.Count > 0)
            {
                <button class="btn btn-secondary btn-sm" style="display:flex;align-items:center;gap:0.4rem;" @onclick="() => showInstructorModal = true">
                    <i class="fa-solid fa-users"></i>
                    <span>Instructores (@selectedInstructorIds.Count/@(instructors.Count))</span>
                </button>
            }
            <div class="week-navigator">
                <button class="btn btn-secondary btn-sm" @onclick="PreviousWeek"><i class="fa-solid fa-chevron-left" style="margin-right:0.3rem;"></i>Anterior</button>
                <span class="week-label">@weekStart.ToString("dd/M") - @weekEnd.ToString("dd/M/yyyy")</span>
                <button class="btn btn-secondary btn-sm" @onclick="NextWeek">Siguiente<i class="fa-solid fa-chevron-right" style="margin-left:0.3rem;"></i></button>
            </div>
        }
    </div>
</div>

@if (currentView == "calendario")
{
<div class="card">
    <div class="card-body" style="padding: 0.5rem;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1rem;">Cargando...</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table calendar-compact reservar-grid">
                    <thead>
                        <tr>
                            <th style="width: 50px;">Hora</th>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = weekStart.AddDays(i);
                                <th style="text-align: center; width: 80px;">
                                    <div style="font-size: 0.75rem;">@dayNames[i]</div>
                                    <div style="font-size: 0.7rem; font-weight: 400; color: var(--text-muted);">@date.ToString("dd/M")</div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int hour = 8; hour <= 21; hour++)
                        {
                            var h = hour;
                            <tr>
                                <td style="font-size: 0.75rem; font-weight: 600; padding: 4px;">@($"{h:00}:00")</td>
                                @for (int i = 0; i < 7; i++)
                                {
                                    var date = weekStart.AddDays(i);
                                    var isPast = date.Date < DateTime.Today || (date.Date == DateTime.Today && h <= DateTime.Now.Hour);
                                    var myBooking = GetMyBookingAt(date, h);
                                    var available = GetAvailableInstructors(date, h);

                                    @if (myBooking is not null)
                                    {
                                        var booking = myBooking;
                                        var isCompleted = booking.Status == "completed";
                                        var isCancelled = booking.Status == "cancelled";
                                        var instName = booking.InstructorName;
                                        <td style="text-align: center; padding: 4px; cursor: pointer;"
                                            class="@(isCompleted ? "calendar-slot-completed" : isCancelled ? "calendar-slot-cancelled" : "calendar-slot-booked")"
                                            title="@(isCompleted ? $"Clase realizada con {instName}" : isCancelled ? $"Clase cancelada con {instName}" : $"Reservada con {instName}")"
                                            @onclick="() => ShowBookingDetail(booking)">
                                            <div style="display:flex;align-items:center;gap:6px;padding:2px 4px;">
                                                @if (isCompleted)
                                                {
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                                }
                                                else if (isCancelled)
                                                {
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                                }
                                                else
                                                {
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                                }
                                                <span style="font-size:0.7rem;font-weight:500;text-align:left;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@instName</span>
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align: center; padding: 4px; cursor: @(available.Count > 0 && !isPast ? "pointer" : "default");"
                                            class="@(isPast ? "calendar-past" : available.Count > 0 ? "calendar-slot-available" : "")"
                                            @onclick="() => OnSlotClick(date, h)">
                                            @if (!isPast && available.Count > 0)
                                            {
                                                <div style="display:flex;align-items:center;justify-content:flex-start;gap:3px;flex-wrap:wrap;height:100%;min-height:28px;padding:2px;" title="@available.Count instructor@(available.Count > 1 ? "es" : "") disponible@(available.Count > 1 ? "s" : "")">
                                                    @foreach (var inst in available)
                                                    {
                                                        var color = GetInstructorColor(inst.Id);
                                                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:@color;"></span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.8rem; flex-wrap: wrap; padding: 0 0.5rem; align-items: center;">
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:14px;height:14px;border-radius:3px;border-left:3px solid #10b981;background:rgba(16,185,129,0.08);"></span>
                    Disponible
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:14px;height:14px;border-radius:3px;border-left:3px solid #f59e0b;background:rgba(245,158,11,0.08);"></span>
                    Confirmada
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:14px;height:14px;border-radius:3px;border-left:3px solid #3b82f6;background:rgba(59,130,246,0.08);"></span>
                    Completada
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;">
                    <span style="display:inline-block;width:14px;height:14px;border-radius:3px;border-left:3px solid #ef4444;background:rgba(239,68,68,0.08);"></span>
                    Cancelada
                </span>
            </div>
        }
    </div>
</div>
}

@if (currentView == "lista")
{
    <div class="card">
        <div class="card-body" style="padding: 0.5rem;">
            @if (allMyBookings is null || !allMyBookings.Any())
            {
                <p class="text-muted" style="padding:1.5rem;">No tenes reservas todavia</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Horario</th>
                                <th>Instructor</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in allMyBookings.OrderByDescending(b => b.ScheduledDate).ThenByDescending(b => b.StartHour))
                            {
                                <tr>
                                    <td>@b.ScheduledDate.ToString("dd/MM/yyyy")</td>
                                    <td style="white-space:nowrap;">@($"{b.StartHour}:00 - {b.StartHour + 1}:00")</td>
                                    <td>@b.InstructorName</td>
                                    <td><span class="status-badge" style="@GetListStatusStyle(b.Status)">@GetListStatusLabel(b.Status)</span></td>
                                    <td>
                                        @if (b.Status == "confirmed" && b.ScheduledDate.Date >= DateTime.Today)
                                        {
                                            <button class="btn btn-sm" style="background:var(--danger);color:white;padding:0.3rem 0.6rem;font-size:0.78rem;"
                                                    @onclick="() => ShowBookingDetail(b)">
                                                <i class="fa-solid fa-ban" style="margin-right:0.3rem;"></i>Cancelar
                                            </button>
                                        }
                                        @if (!string.IsNullOrEmpty(b.MeetLink) && b.Status == "confirmed")
                                        {
                                            <a href="@b.MeetLink" target="_blank" class="btn btn-sm" style="background:var(--info);color:white;padding:0.3rem 0.6rem;font-size:0.78rem;">
                                                <i class="fa-solid fa-video" style="margin-right:0.3rem;"></i>Meet
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (showInstructorModal)
{
    <div class="modal-overlay" @onclick="() => showInstructorModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="display:flex;justify-content:space-between;align-items:center;">
                <h3 style="margin:0;font-size:1rem;">Seleccionar instructores</h3>
                <div style="display:flex;gap:0.5rem;">
                    <button class="btn btn-sm btn-secondary" @onclick="SelectAllInstructors"><i class="fa-solid fa-check-double" style="margin-right:0.3rem;"></i>Todos</button>
                    <button class="btn btn-sm btn-secondary" @onclick="SelectNoneInstructors"><i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Ninguno</button>
                </div>
            </div>
            <div class="modal-body" style="max-height:350px;overflow-y:auto;padding:0.75rem 1rem;">
                @if (instructors is not null)
                {
                    @foreach (var inst in instructors)
                    {
                        var id = inst.Id;
                        var isChecked = selectedInstructorIds.Contains(id);
                        var color = GetInstructorColor(id);
                        <label style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.4rem;border-radius:6px;cursor:pointer;transition:background 0.15s;@(isChecked ? $"background:{color}11;" : "")"
                               class="instructor-modal-row">
                            <input type="checkbox" checked="@isChecked" @onchange="() => ToggleInstructor(id)"
                                   style="accent-color:@color;width:16px;height:16px;" />
                            <span class="instructor-dot" style="background:@color;"></span>
                            <span style="font-size:0.85rem;@(isChecked ? "font-weight:600;" : "color:var(--text-secondary);")">
                                @($"{inst.FirstName} {inst.LastName}".Trim())
                            </span>
                        </label>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary btn-sm" @onclick="() => showInstructorModal = false"><i class="fa-solid fa-check" style="margin-right:0.3rem;"></i>Listo</button>
            </div>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal-overlay" @onclick="() => showModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Reservar clase</h3>
            </div>
            <div class="modal-body">
                <p style="margin-bottom: 0.75rem;">
                    <strong>@modalDate.ToString("dddd dd/MM/yyyy")</strong> a las <strong>@($"{modalHour:00}:00 - {modalHour + 1:00}:00")</strong>
                </p>
                <p style="font-size: 0.85rem; margin-bottom: 0.75rem;">Selecciona un instructor:</p>
                <div class="modal-instructor-list">
                    @foreach (var inst in modalInstructors)
                    {
                        var id = inst.Id;
                        var color = GetInstructorColor(id);
                        var name = $"{inst.FirstName} {inst.LastName}".Trim();
                        <button class="modal-instructor-btn @(modalSelectedInstructorId == id ? "selected" : "")"
                                style="border-left: 3px solid @color;"
                                @onclick="() => { modalSelectedInstructorId = id; modalSelectedInstructorName = name; }">
                            @name (@inst.Username)
                        </button>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showModal = false"><i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cancelar</button>
                <button class="btn btn-primary" @onclick="DoBooking" disabled="@(isBooking || modalSelectedInstructorId == 0)">
                    <i class="fa-solid fa-calendar-plus" style="margin-right:0.3rem;"></i>@(isBooking ? "Reservando..." : "Confirmar Reserva")
                </button>
            </div>
        </div>
    </div>
}

@if (showDetailModal && detailBooking is not null)
{
    <div class="modal-overlay" @onclick="() => showDetailModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Detalle de clase</h3>
            </div>
            <div class="modal-body">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
                    @if (detailBooking.Status == "completed")
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(16,185,129,0.12);color:#10b981;padding:4px 10px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                            @SvgIcons.CheckCircle Realizada
                        </span>
                    }
                    else
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;background:rgba(59,130,246,0.12);color:#3b82f6;padding:4px 10px;border-radius:20px;font-size:0.8rem;font-weight:600;">
                            @SvgIcons.Calendar Reservada
                        </span>
                    }
                </div>

                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.Calendar</span>
                        <span><strong>Fecha:</strong> @detailBooking.ScheduledDate.ToString("dddd dd/MM/yyyy")</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.Clock</span>
                        <span><strong>Horario:</strong> @($"{detailBooking.StartHour:00}:00 - {detailBooking.StartHour + 1:00}:00")</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.User</span>
                        <span><strong>Instructor:</strong> @detailBooking.InstructorName</span>
                    </div>

                    @if (!string.IsNullOrEmpty(detailBooking.MeetLink))
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.ExternalLink</span>
                            <a href="@detailBooking.MeetLink" target="_blank" rel="noopener" class="btn btn-sm" style="background:#10b981;color:white;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                <i class="fa-solid fa-video" style="margin-right:0.3rem;"></i>Unirse a la clase
                            </a>
                        </div>
                    }
                    else if (detailBooking.Status == "confirmed")
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="color:var(--text-muted);width:20px;display:flex;justify-content:center;">@SvgIcons.ExternalLink</span>
                            <span style="font-size:0.85rem;color:var(--text-muted);">El link de Meet se asignara antes de la clase</span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDetailModal = false"><i class="fa-solid fa-xmark" style="margin-right:0.3rem;"></i>Cerrar</button>
                @if (detailBooking.Status == "confirmed")
                {
                    <button class="btn btn-danger" @onclick="CancelBooking" disabled="@isCancelling">
                        <i class="fa-solid fa-calendar-xmark" style="margin-right:0.3rem;"></i>@(isCancelling ? "Cancelando..." : "Cancelar Reserva")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isBooking;
    private int? remainingTokens;
    private int bookedClasses;
    private int usedClasses;
    private string currentView = "calendario";

    private List<UserManageDto>? instructors;
    private HashSet<int> selectedInstructorIds = new();
    private Dictionary<int, List<AvailabilityDto>> instructorAvailability = new();
    private Dictionary<int, List<WeekAvailabilityDto>> instructorWeekOverrides = new();
    private List<BookingDto>? weekBookings;
    private List<BookingDto>? myBookings;
    private List<BookingDto>? allMyBookings;

    private DateTime weekStart;
    private DateTime weekEnd;
    private string[] dayNames = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };

    // Instructor modal
    private bool showInstructorModal;

    // Modal state
    private bool showModal;
    private DateTime modalDate;
    private int modalHour;
    private List<UserManageDto> modalInstructors = new();
    private int modalSelectedInstructorId;
    private string modalSelectedInstructorName = "";

    // Detail modal state
    private bool showDetailModal;
    private BookingDto? detailBooking;
    private bool isCancelling;

    // Colors for instructors
    private string[] instructorColors = { "#10b981", "#3b82f6", "#f59e0b", "#ef4444", "#8b5cf6", "#ec4899", "#14b8a6", "#f97316" };

    protected override async Task OnInitializedAsync()
    {
        // Start on current week (Monday)
        var today = DateTime.Today;
        var dayOfWeek = (int)today.DayOfWeek;
        var daysToMonday = dayOfWeek == 0 ? 6 : dayOfWeek - 1;
        weekStart = today.AddDays(-daysToMonday);
        weekEnd = weekStart.AddDays(6);

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var instructorsTask = Api.GetInstructorsAsync();
            var dashTask = Api.GetUserDashboardAsync();
            await Task.WhenAll(instructorsTask, dashTask);

            instructors = instructorsTask.Result ?? new();

            var dash = dashTask.Result;
            if (dash is not null)
            {
                remainingTokens = dash.RemainingTokens;
                bookedClasses = dash.BookedClasses;
                usedClasses = dash.UsedClasses;
            }

            // Select all instructors by default
            selectedInstructorIds = new HashSet<int>(instructors.Select(i => i.Id));

            // Load availability for each instructor in parallel
            var availTasks = instructors.Select(async inst =>
            {
                var avail = await Api.GetInstructorAvailabilityAsync(inst.Id);
                return (inst.Id, Availability: avail ?? new List<AvailabilityDto>());
            }).ToList();

            var results = await Task.WhenAll(availTasks);
            instructorAvailability = results.ToDictionary(r => r.Id, r => r.Availability);

            // Load week bookings and week overrides
            await LoadWeekData();
        }
        catch
        {
            ToastService.Error("Error al cargar los datos");
        }

        isLoading = false;
    }

    private async Task LoadWeekData()
    {
        try
        {
            var weekTask = Api.GetWeekBookingsAsync(weekStart, weekEnd);
            var myTask = Api.GetMyBookingsAsync();
            await Task.WhenAll(weekTask, myTask);
            weekBookings = weekTask.Result;
            allMyBookings = myTask.Result ?? new();
            myBookings = allMyBookings.Where(b =>
                b.ScheduledDate.Date >= weekStart.Date && b.ScheduledDate.Date <= weekEnd.Date
                && (b.Status == "confirmed" || b.Status == "completed" || b.Status == "cancelled")).ToList();

            // Reload week overrides for all instructors
            if (instructors is not null)
            {
                var tasks = instructors.Select(async inst =>
                {
                    var overrides = await Api.GetWeekAvailabilityAsync(inst.Id, weekStart, weekEnd);
                    return (inst.Id, Overrides: overrides ?? new List<WeekAvailabilityDto>());
                }).ToList();
                var results = await Task.WhenAll(tasks);
                instructorWeekOverrides = results.ToDictionary(r => r.Id, r => r.Overrides);
            }
        }
        catch
        {
            weekBookings = new();
        }
    }

    private string GetInstructorColor(int instructorId)
    {
        if (instructors is null) return instructorColors[0];
        var index = instructors.FindIndex(i => i.Id == instructorId);
        return index >= 0 ? instructorColors[index % instructorColors.Length] : instructorColors[0];
    }

    private List<UserManageDto> GetAvailableInstructors(DateTime date, int hour)
    {
        if (instructors is null) return new();

        var dayOfWeek = (int)date.DayOfWeek;
        var result = new List<UserManageDto>();

        foreach (var inst in instructors)
        {
            if (!selectedInstructorIds.Contains(inst.Id)) continue;

            // Determine effective availability considering week overrides
            bool isAvailable;

            if (instructorWeekOverrides.TryGetValue(inst.Id, out var overrides))
            {
                var weekOverride = overrides.FirstOrDefault(o => o.Date.Date == date.Date && o.StartHour == hour);
                if (weekOverride is not null)
                {
                    isAvailable = weekOverride.IsActive;
                }
                else
                {
                    // No override -> use general availability
                    isAvailable = instructorAvailability.TryGetValue(inst.Id, out var avail)
                        && avail.Any(a => a.DayOfWeek == dayOfWeek && a.StartHour == hour && a.IsActive);
                }
            }
            else
            {
                isAvailable = instructorAvailability.TryGetValue(inst.Id, out var avail)
                    && avail.Any(a => a.DayOfWeek == dayOfWeek && a.StartHour == hour && a.IsActive);
            }

            if (!isAvailable) continue;

            // Check if there's already a booking for this instructor at this date+hour
            var isBooked = weekBookings?.Any(b =>
                b.InstructorId == inst.Id &&
                b.ScheduledDate.Date == date.Date &&
                b.StartHour == hour) ?? false;
            if (isBooked) continue;

            result.Add(inst);
        }

        return result;
    }

    private void ToggleInstructor(int id)
    {
        if (selectedInstructorIds.Contains(id))
            selectedInstructorIds.Remove(id);
        else
            selectedInstructorIds.Add(id);
    }

    private void SelectAllInstructors()
    {
        if (instructors is not null)
            selectedInstructorIds = new HashSet<int>(instructors.Select(i => i.Id));
    }

    private void SelectNoneInstructors()
    {
        selectedInstructorIds = new();
    }

    private async Task PreviousWeek()
    {
        weekStart = weekStart.AddDays(-7);
        weekEnd = weekEnd.AddDays(-7);
        await LoadWeekData();
    }

    private async Task NextWeek()
    {
        weekStart = weekStart.AddDays(7);
        weekEnd = weekEnd.AddDays(7);
        await LoadWeekData();
    }

    private void OnSlotClick(DateTime date, int hour)
    {
        var isPast = date.Date < DateTime.Today || (date.Date == DateTime.Today && hour <= DateTime.Now.Hour);
        if (isPast) return;

        var available = GetAvailableInstructors(date, hour);
        if (available.Count == 0) return;

        modalDate = date;
        modalHour = hour;
        modalInstructors = available;
        modalSelectedInstructorId = available.Count == 1 ? available[0].Id : 0;
        modalSelectedInstructorName = available.Count == 1 ? $"{available[0].FirstName} {available[0].LastName}".Trim() : "";
        showModal = true;
    }

    private async Task DoBooking()
    {
        if (modalSelectedInstructorId == 0) return;
        if (remainingTokens.HasValue && remainingTokens <= 0)
        {
            ToastService.Error("No tenes clases disponibles. Pedile al administrador que te cargue un pack.");
            return;
        }

        isBooking = true;
        try
        {
            var request = new CreateBookingRequest
            {
                InstructorId = modalSelectedInstructorId,
                ScheduledDate = modalDate,
                StartHour = modalHour
            };

            var result = await Api.CreateBookingAsync(request);
            if (result is not null)
            {
                ToastService.Success($"Clase reservada con {modalSelectedInstructorName}");
                showModal = false;
                if (remainingTokens.HasValue) remainingTokens--;
                bookedClasses++;
                await LoadWeekData();
            }
            else
            {
                ToastService.Error("Error al reservar la clase");
            }
        }
        catch
        {
            ToastService.Error("Error al reservar la clase");
        }
        isBooking = false;
    }

    private BookingDto? GetMyBookingAt(DateTime date, int hour)
    {
        return myBookings?.FirstOrDefault(b =>
            b.ScheduledDate.Date == date.Date && b.StartHour == hour);
    }

    private void ShowBookingDetail(BookingDto booking)
    {
        detailBooking = booking;
        showDetailModal = true;
    }

    private async Task CancelBooking()
    {
        if (detailBooking is null) return;

        isCancelling = true;
        try
        {
            var success = await Api.CancelBookingAsync(detailBooking.Id);
            if (success)
            {
                ToastService.Success("Reserva cancelada");
                showDetailModal = false;
                if (remainingTokens.HasValue) remainingTokens++;
                bookedClasses--;
                await LoadWeekData();
            }
            else
            {
                ToastService.Error("No se pudo cancelar la reserva");
            }
        }
        catch
        {
            ToastService.Error("Error al cancelar la reserva");
        }
        isCancelling = false;
    }

    private string GetListStatusStyle(string s) => s switch
    {
        "confirmed" => "background:rgba(245,158,11,0.1);color:#b45309;",
        "completed" => "background:rgba(59,130,246,0.1);color:#2563eb;",
        "cancelled" => "background:rgba(239,68,68,0.1);color:#dc2626;",
        _ => "background:rgba(100,116,139,0.1);color:#64748b;"
    };

    private string GetListStatusLabel(string s) => s switch
    {
        "confirmed" => "Confirmada",
        "completed" => "Completada",
        "cancelled" => "Cancelada",
        _ => s
    };
}
